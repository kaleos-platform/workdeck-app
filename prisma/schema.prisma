// 쿠팡 광고 리포트 매니저 데이터 모델

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 사용자 모델 (Supabase Auth와 연동)
model User {
  id        String     @id // Supabase Auth UUID를 그대로 사용 (no default)
  email     String     @unique
  name      String?
  avatarUrl String?

  // 소유한 워크스페이스
  workspace Workspace?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 워크스페이스 (쿠팡 사업자 단위)
model Workspace {
  id      String @id @default(cuid())
  name    String // 쿠팡 사업자명

  // 소유 사용자
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // 연관 데이터
  reportUploads ReportUpload[]
  adRecords     AdRecord[]
  dailyMemos    DailyMemo[]

  createdAt DateTime @default(now())
}

// 업로드 이력
model ReportUpload {
  id          String   @id @default(cuid())
  fileName    String
  uploadedAt  DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 이 업로드에서 파싱된 광고 데이터
  adRecords AdRecord[]

  @@index([workspaceId])
}

// 광고 데이터 행 (Excel 한 행 = 하나의 AdRecord)
model AdRecord {
  id           String   @id @default(cuid())
  date         DateTime
  adType       String   // 광고유형 (예: 키워드 광고, 상품 광고)
  campaignId   String
  campaignName String
  adGroup      String?  // 광고그룹
  placement    String?  // 광고 노출 지면
  productName  String?  // 광고집행 상품명
  optionId     String?  // 광고집행 옵션ID
  keyword      String?  // 키워드 (없을 수 있음)

  // 노출·클릭
  impressions Int
  clicks      Int
  adCost      Decimal  @db.Decimal(18, 2) // 광고비
  ctr         Decimal  @db.Decimal(10, 4) // 클릭률

  // 1일 전환 지표
  orders1d    Int
  revenue1d   Decimal  @db.Decimal(18, 2) // 총 전환매출액 (1일)
  roas1d      Decimal  @db.Decimal(10, 4) // 총 광고수익률 (1일)

  // 14일 전환 지표
  orders14d   Int
  revenue14d  Decimal  @db.Decimal(18, 2) // 총 전환매출액 (14일)
  roas14d     Decimal  @db.Decimal(10, 4) // 총 광고수익률 (14일)

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 소속 업로드 이력
  reportId String
  report   ReportUpload @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, campaignId, adType, keyword, adGroup, optionId])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, date])
}

// 일자별 메모 (캠페인별 광고 작업 이력)
model DailyMemo {
  id         String   @id @default(cuid())
  campaignId String
  date       DateTime
  content    String

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 워크스페이스 + 캠페인 + 날짜 조합은 유일
  @@unique([workspaceId, campaignId, date])
  @@index([workspaceId, campaignId])
}
