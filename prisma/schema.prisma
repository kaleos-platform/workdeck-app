// 쿠팡 광고 리포트 매니저 데이터 모델

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 데이터 수집 열거형 ──────────────────────────────────────────────────────

enum CollectionStatus {
  PENDING
  RUNNING
  DOWNLOADING
  PARSING
  COMPLETED
  FAILED
}

// ─── 실행 태스크 열거형 ──────────────────────────────────────────────────────

enum ActionType {
  REMOVE_KEYWORD
  ADJUST_BID
  PAUSE_CAMPAIGN
  RESUME_CAMPAIGN
  ADJUST_BUDGET
}

enum ExecutionStatus {
  PENDING_APPROVAL
  APPROVED
  EXECUTING
  COMPLETED
  FAILED
  ROLLED_BACK
}

// ─── AI 분석 열거형 ──────────────────────────────────────────────────────────

enum AnalysisType {
  DAILY_REVIEW
  KEYWORD_AUDIT
  BUDGET_OPTIMIZATION
  CAMPAIGN_SCORING
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Workdeck OS 열거형 ───────────────────────────────────────────────────────

enum SpaceType {
  PERSONAL
  ORGANIZATION
}

enum SpaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── 발주 예측 열거형 ─────────────────────────────────────────────────────────

// 발주 계획 상태
enum ReorderPlanStatus {
  DRAFT // 초안 — 자유 편집, 측정 안 함
  FINALIZED // 예측 검증 시작(UI "확정") — 예측 동결 + 신뢰도 측정 대상. 직접 편집 불가(revert→새 revision)
  CONSUMED // (폐기 예정) 레거시 — settle가 더는 이 상태로 전환하지 않음. 읽기 호환만 유지
}

// 확정 스냅샷 출처 — 진짜 확정 시점 값 vs 마이그 backfill 값 구분
enum ReorderSnapshotSource {
  LIVE // 확정 액션 시점에 동결된 실제 값
  BACKFILLED // 마이그레이션이 당시 plan-item 현재값으로 채운 근사값
}

// 적중률 레코드 유효성 — revert/supersede 시 삭제 대신 무효화 (학습은 ACTIVE만)
enum ReorderAccuracyValidity {
  ACTIVE // 유효 — 학습/제안 집계에 사용
  INVALIDATED // 무효 — 측정 근거 불충분/오류로 제외
  SUPERSEDED // 대체됨 — 계획이 revert되어 새 revision으로 대체
}

// 옵션별 평가 진행 상태 (plan 단위 정산 전환을 대체)
enum ReorderEvaluationStatus {
  PENDING // 확정 전 또는 평가창 미경과
  ELIGIBLE // 평가창 경과 — 정산 대기
  MEASURED // 정산 완료 (accuracy 기록됨)
  INVALIDATED // revert/supersede로 제외
}

// 발주 예측 모델 종류
enum ReorderForecastModel {
  SMA // 단순 이동평균
  WMA // 가중 이동평균
  HW // Holt-Winters (계절성)
  CROSTON // Croston/SBA (간헐적 수요)
  BAYES // Bayesian Poisson-Gamma (콜드스타트)
  MANUAL // 사용자 직접 입력
}

// ─── 셀러 허브 열거형 ─────────────────────────────────────────────────────────

// 프로모션 유형
enum PromotionType {
  NONE // 프로모션 없음
  FLAT // 고정 할인 금액
  PERCENT // 비율 할인
  COUPON // 쿠폰 할인
  MIN_PRICE // 최소 판매가 ceiling — column 할인 결과가 이 값보다 높으면 강제 인하
}

// 판매채널 상품 상태 — 시스템 재고 0일 때는 effective status가 SOLD_OUT으로 표시됨 (DB에는 저장 X).
enum ProductListingStatus {
  ACTIVE
  SUSPENDED
}

// 상품 마스터 상태 — INACTIVE는 기존 이력은 보존하되 신규 작업 선택에서 제외.
enum InvProductStatus {
  ACTIVE
  INACTIVE
}

// ─── 사용자 모델 (Supabase Auth와 연동) ──────────────────────────────────────

model User {
  id        String  @id // Supabase Auth UUID를 그대로 사용 (no default)
  email     String  @unique
  name      String?
  avatarUrl String?

  // 소유한 워크스페이스 (기존 — 점진 전환 기간 동안 유지)
  workspace Workspace?

  // Workdeck OS: 공간 멤버십
  spaceMemberships SpaceMember[]

  // 발주 계획 (작성자)
  reorderPlans ReorderPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 워크스페이스 (쿠팡 사업자 단위)
model Workspace {
  id   String @id @default(cuid())
  name String // 쿠팡 사업자명

  // 소유 사용자
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // 연관 데이터
  reportUploads   ReportUpload[]
  adRecords       AdRecord[]
  dailyMemos      DailyMemo[]
  campaignMetas   CampaignMeta[]
  keywordStatuses KeywordStatus[]
  campaignTargets CampaignTarget[]
  productStatuses ProductStatus[]

  // AI 분석 리포트
  analysisReports AnalysisReport[]

  // 실행 태스크
  executionTasks ExecutionTask[]
  safetyLimits   SafetyLimits?

  // 비즈니스 에이전트
  businessAgent BusinessAgent?

  // 학습형 분석 규칙
  analysisRules AnalysisRule[]

  // 분석 자동 스케줄
  analysisSchedule AnalysisSchedule?

  // 데이터 수집 관련
  coupangCredential   CoupangCredential?
  collectionSchedule  CollectionSchedule?
  collectionRuns      CollectionRun[]
  coupangBackfillJobs CoupangBackfillJob[]

  // 재고 관리
  inventoryUploads          InventoryUpload[]
  inventoryRecords          InventoryRecord[]
  inventoryExcludedProducts InventoryExcludedProduct[]
  inventoryAnalyses         InventoryAnalysis[]

  createdAt DateTime @default(now())
}

// 업로드 이력
model ReportUpload {
  id          String   @id @default(cuid())
  fileName    String
  uploadedAt  DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime

  // 처리 결과 통계
  totalRows     Int?
  insertedRows  Int?
  duplicateRows Int?
  skippedRows   Int?

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 이 업로드에서 파싱된 광고 데이터
  adRecords AdRecord[]

  @@index([workspaceId])
}

// 광고 데이터 행 (Excel 한 행 = 하나의 AdRecord)
model AdRecord {
  id           String   @id @default(cuid())
  date         DateTime
  adType       String // 광고유형 (예: 키워드 광고, 상품 광고)
  campaignId   String
  campaignName String
  adGroup      String? // 광고그룹
  placement    String? // 광고 노출 지면
  productName  String? // 광고집행 상품명
  optionId     String? // 광고집행 옵션ID
  keyword      String? // 키워드 (없을 수 있음)

  // 노출·클릭
  impressions Int
  clicks      Int
  adCost      Decimal @db.Decimal(18, 2) // 광고비
  ctr         Decimal @db.Decimal(10, 4) // 클릭률

  // 1일 전환 지표
  orders1d  Int
  revenue1d Decimal @db.Decimal(18, 2) // 직접 전환매출액 (1일)
  roas1d    Decimal @db.Decimal(10, 4) // 직접 광고수익률 (1일)

  // NCA 공통 필드
  material String? // 소재 (NCA: 소재 컬럼)

  // NCA 동영상 지표 (없으면 null)
  videoViews3s   Int? // 동영상 3초 조회
  avgPlayTime    Decimal? @db.Decimal(10, 2) // 평균 재생 시간
  videoViews25p  Int? // 25% 재생수
  videoViews50p  Int? // 50% 재생수
  videoViews75p  Int? // 75% 재생수
  videoViews100p Int? // 100% 재생수
  costPerView3s  Decimal? @db.Decimal(18, 2) // 동영상 3초 조회당 비용
  engagements    Int? // 참여수
  engagementRate Decimal? @db.Decimal(10, 4) // 참여율

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 소속 업로드 이력
  reportId String
  report   ReportUpload @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, campaignId, adType, keyword, adGroup, optionId])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, campaignId, date])
  @@index([workspaceId, date])
}

// 캠페인 메타 (표시명 커스터마이징)
model CampaignMeta {
  id           String    @id @default(cuid())
  workspaceId  String
  campaignId   String
  displayName  String
  isCustomName Boolean   @default(false)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, campaignId])
  @@index([workspaceId])
}

// 키워드 제거 상태 관리
model KeywordStatus {
  id          String    @id @default(cuid())
  workspaceId String
  campaignId  String
  keyword     String
  removedAt   DateTime?
  removedMemo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, keyword])
  @@index([workspaceId, campaignId])
}

// 캠페인 일 예산 / 목표 ROAS 설정 이력 (effectiveDate 기반)
model CampaignTarget {
  id            String   @id @default(cuid())
  workspaceId   String
  campaignId    String
  effectiveDate DateTime @db.Date // 이 값이 적용되기 시작하는 날짜
  dailyBudget   Int? // 일 예산 (원), null = 미설정
  targetRoas    Float? // 목표 ROAS (%), null = 미설정
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, effectiveDate])
  @@index([workspaceId, campaignId, effectiveDate])
}

// 상품 제거 상태 관리
model ProductStatus {
  id          String    @id @default(cuid())
  workspaceId String
  campaignId  String
  productName String
  optionId    String    @default("")
  removedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, productName, optionId])
  @@index([workspaceId, campaignId])
}

// 일자별 메모 (캠페인별 광고 작업 이력)
model DailyMemo {
  id         String   @id @default(cuid())
  campaignId String
  date       DateTime
  content    String

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 워크스페이스 + 캠페인 + 날짜 조합은 유일
  @@unique([workspaceId, campaignId, date])
  @@index([workspaceId, campaignId])
}

// ─── Workdeck OS 모델 ─────────────────────────────────────────────────────────

// 공간 (개인 or 조직 테넌트)
model Space {
  id   String    @id @default(cuid())
  name String
  type SpaceType @default(PERSONAL)

  members       SpaceMember[]
  deckInstances DeckInstance[]

  // 통합 재고 관리 (Inv)
  invProducts         InvProduct[]
  invLocations        InvStorageLocation[]
  invMovements        InvMovement[]
  invStockLevels      InvStockLevel[]
  invImportHistories  InvImportHistory[]
  invReconciliations  InvReconciliation[]
  invLocationMappings InvLocationProductMap[]
  invSettings         InvSettings?
  invProductGroups    InvProductGroup[]

  // 통합 배송 관리 (Del)
  delShippingMethods      DelShippingMethod[]
  delBatches              DelBatch[]
  delOrders               DelOrder[]
  delIntegrationHistories DelIntegrationHistory[]
  delColumnMappingPresets DelColumnMappingPreset[]
  channelProductAliases   ChannelProductAlias[]
  delShippingMethodLabels DelShippingMethodLabel[]

  // 셀러 허브 공용 (Seller Hub)
  channels               Channel[]
  channelTypeDefs        ChannelTypeDef[]
  brands                 Brand[]
  productPricingSettings ProductPricingSettings?
  optionCodeAliases      SpaceOptionCodeAlias[]
  productListings        ProductListing[]
  channelStockMovements  ChannelStockMovement[]
  channelProducts        ChannelProduct[]
  productionRuns         ProductionRun[]
  pricingScenarios       PricingScenario[]

  // 발주 계획
  reorderPlans ReorderPlan[]

  // 온보딩 카드 닫힘 시각 (사용자가 명시적으로 X 클릭 시 기록)
  onboardingDismissedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Sales Content Deck ───
  products             Product[]
  personas             Persona[]
  brandProfile         BrandProfile?
  workspaceAiCredits   WorkspaceAiCredit[]
  imageGenerationLogs  ImageGenerationLog[]
  textGenerationLogs   TextGenerationLog[]
  ideations            Ideation[]
  templates            Template[]
  salesContentChannels SalesContentChannel[]
  contents             Content[]
  contentAssets        ContentAsset[]
  contentVersions      ContentVersion[]
  contentDeployments   ContentDeployment[]
  contentClickEvents   ContentClickEvent[]
  channelCredentials   ChannelCredential[]
  salesContentJobs     SalesContentJob[]
  deploymentMetrics    DeploymentMetric[]
  improvementRules     ImprovementRule[]

  // ─── 재무 관리 Deck (Finance) ───
  finAccounts         FinAccount[]
  finLiabilities      FinLiability[]
  finCategories       FinCategory[]
  finClassRules       FinClassRule[]
  finMappingPresets   FinMappingPreset[]
  finImports          FinImport[]
  finStagedRows       FinStagedRow[]
  finTransactions     FinTransaction[]
  finBalanceSnapshots FinBalanceSnapshot[]

  // ─── 채용 관리 Deck (Hiring) ───
  hiringStores           HiringStore[]
  hiringPositions        HiringPosition[]
  hiringPostings         HiringPosting[]
  hiringPostingPositions HiringPostingPosition[]
  hiringContents         HiringContent[]
  hiringDetailTemplates  HiringDetailTemplate[]
  hiringApplications     HiringApplication[]
  hiringBlacklists       HiringBlacklist[]
  hiringMessageTemplates HiringMessageTemplate[]


  // ─── 블로그 운영 Deck (Blog Ops) ───
  boProducts            BoProduct[]
  boIdeations           BoIdeation[]
  boMaterials           BoMaterial[]
  boPosts               BoPost[]
  boPostVersions        BoPostVersion[]
  boChannels            BoChannel[]
  boPostVariants        BoPostVariant[]
  boDeployments         BoDeployment[]
  boJobs                BoJob[]
  boChannelCredentials  BoChannelCredential[]
}

// 공간 멤버십 + 역할
model SpaceMember {
  id      String          @id @default(cuid())
  spaceId String
  userId  String
  role    SpaceMemberRole @default(MEMBER)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([spaceId, userId])
  @@index([userId])
}

// 카드 앱 카탈로그 (전역 정의)
model DeckApp {
  id          String  @id // "coupang-ads", "osmu", "commerce-ops"
  name        String
  description String?
  isActive    Boolean @default(true)

  instances DeckInstance[]
}

// Space에서 활성화된 카드 인스턴스
model DeckInstance {
  id        String  @id @default(cuid())
  spaceId   String
  deckAppId String
  isActive  Boolean @default(true)

  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  deckApp DeckApp @relation(fields: [deckAppId], references: [id])

  createdAt DateTime @default(now())

  @@unique([spaceId, deckAppId])
  @@index([spaceId])
}

// ─── 데이터 수집 모델 ────────────────────────────────────────────────────────

// 쿠팡 로그인 자격증명 (워크스페이스당 1개)
model CoupangCredential {
  id                 String    @id @default(cuid())
  workspaceId        String    @unique
  loginId            String
  loginPassword      String
  encryptionIv       String
  isActive           Boolean   @default(true)
  // 판매분석(VENDOR) 수집 허가 — isActive(크레덴셜 유효)와 의미 분리.
  // false 면 워커가 inventory_health 만 수집하고 VENDOR(로켓그로스 일별 판매)는 건너뛴다.
  collectVendorSales Boolean   @default(true)
  lastLoginAt        DateTime?
  lastError          String?
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// 자동 수집 스케줄 (워크스페이스당 1개)
model CollectionSchedule {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  enabled        Boolean   @default(true)
  cronExpression String    @default("30 12 * * *")
  timezone       String    @default("Asia/Seoul")
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum CoupangBackfillStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

// 콜드스타트 판매분석 백필 잡 — 웹은 Wing 직접 수집 불가하므로 워커가 폴링해 실행.
// 워커: 과거 days 일 VENDOR 수집 → coupang-sales-sync range 변환(step-2) 체이닝.
model CoupangBackfillJob {
  id            String                @id @default(cuid())
  workspaceId   String
  days          Int // 과거 N일 (어제부터 역순). range 잡이면 endDate−startDate+1(포함).
  // range 백필(캘린더 특정 구간). 둘 다 null이면 days 기반(어제부터 역순) 잡.
  startDate     String? // 수집 시작일 KST YYYY-MM-DD (oldest)
  endDate       String? // 수집 종료일 KST YYYY-MM-DD (newest, 보통 어제)
  trigger       String                @default("backfill") // backfill(UI 과거수집) | scheduled(매일 cron)
  status        CoupangBackfillStatus @default(PENDING)
  claimedAt     DateTime?
  claimedBy     String?
  completedAt   DateTime?
  collected     Int                   @default(0) // 적재된 일자 수
  converted     Int                   @default(0) // OUTBOUND 변환된 일자 수
  // 이력 요약 (수집 결과 가시화) — 잡 전체 누적
  duplicateRows Int                   @default(0) // 중복으로 건너뛴 VENDOR 행 수
  outboundCount Int                   @default(0) // 생성/갱신된 OUTBOUND(재고차감) 이동 건수
  revenueSum    Decimal               @default(0) @db.Decimal(18, 2) // 매출 합
  orderSum      Int                   @default(0) // 주문 합
  salesQtySum   Int                   @default(0) // 판매량 합
  error         String?
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([workspaceId, status])
}

// 수집 실행 이력
model CollectionRun {
  id               String           @id @default(cuid())
  workspaceId      String
  status           CollectionStatus @default(PENDING)
  triggeredBy      String
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?
  uploadId         String?
  // 수동 수집 작업 스코프 — 어떤 작업을 실행할지. 자동(scheduled)은 둘 다 true(전체).
  // 판매(VENDOR)는 수동 수집에서 항상 제외되므로 별도 필드 없음(자동 cron 전용).
  collectAds       Boolean          @default(true) // 광고 데이터 수집
  collectInventory Boolean          @default(true) // 재고현황(HEALTH) 수집
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

// ─── AI 분석 리포트 ─────────────────────────────────────────────────────────

model AnalysisReport {
  id          String         @id @default(cuid())
  workspaceId String
  periodStart DateTime
  periodEnd   DateTime
  reportType  AnalysisType
  summary     String         @db.Text
  suggestions Json
  metadata    Json?
  status      AnalysisStatus @default(PENDING)
  triggeredBy String         @default("manual")
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

// ─── 반자동 실행 인프라 ───────────────────────────────────────────────────────

// 실행 태스크 (AI 제안 → 승인 → 실행 흐름)
model ExecutionTask {
  id               String          @id @default(cuid())
  workspaceId      String
  analysisReportId String?
  actionType       ActionType
  campaignId       String
  target           String
  params           Json
  status           ExecutionStatus @default(PENDING_APPROVAL)
  beforeState      Json?
  afterState       Json?
  approvedAt       DateTime?
  approvedBy       String?
  executedAt       DateTime?
  error            String?
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([workspaceId, status])
}

// 안전 제한 설정 (워크스페이스당 1개)
model SafetyLimits {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  maxBidChangePct     Int       @default(30)
  maxKeywordsPerBatch Int       @default(20)
  maxBudgetChangePct  Int       @default(50)
  requireApproval     Boolean   @default(true)
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// 학습형 분석 규칙 (사용자/모델/시스템이 추가한 분석 기준)
model AnalysisRule {
  id           String    @id @default(cuid())
  workspaceId  String
  rule         String    @db.Text
  source       String // "user" | "model" | "system"
  isActive     Boolean   @default(true)
  appliedCount Int       @default(0)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceId, isActive])
}

// 분석 자동 스케줄 (워크스페이스당 1개)
model AnalysisSchedule {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  enabled                Boolean   @default(true)
  intervalDays           Int       @default(7)
  analysisHour           Int?
  triggerAfterCollection Boolean   @default(false)
  slackNotify            Boolean   @default(true)
  lastAnalyzedAt         DateTime?
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// 비즈니스 에이전트 (의식주의 Slack 에이전트)
model BusinessAgent {
  id             String     @id @default(cuid())
  workspaceId    String     @unique
  slackChannelId String?
  slackBotToken  String?
  isActive       Boolean    @default(true)
  lastActiveAt   DateTime?
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs           AgentLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model AgentLog {
  id        String        @id @default(cuid())
  agentId   String
  type      String // command, notification, error
  command   String? // 사용자 입력 명령 (예: "상태", "분석")
  response  String? // 에이전트 응답 요약
  channel   String? // Slack 채널 ID
  agent     BusinessAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([agentId, createdAt(sort: Desc)])
}

// ─── 워커 헬스체크 ────────────────────────────────────────────

// 워커 프로세스 heartbeat — 서비스별 마지막 핑 시각.
// cron이 이 값을 보고 워커 다운을 감지하여 Slack 알림한다.
model WorkerHeartbeat {
  id         String   @id @default(cuid())
  service    String   @unique // 예: "inventory-collector"
  lastPingAt DateTime
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── 재고 관리 ────────────────────────────────────────────────

// 재고 엑셀 업로드 이력
model InventoryUpload {
  id           String   @id @default(cuid())
  fileName     String
  fileType     String // INVENTORY_HEALTH | VENDOR_ITEM_METRICS
  uploadedAt   DateTime @default(now())
  snapshotDate DateTime // 데이터 기준일
  totalRows    Int?
  insertedRows Int?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  inventoryRecords InventoryRecord[]

  @@index([workspaceId])
}

// 재고 / 상품 성과 레코드
model InventoryRecord {
  id           String   @id @default(cuid())
  workspaceId  String
  snapshotDate DateTime
  fileType     String // INVENTORY_HEALTH | VENDOR_ITEM_METRICS

  // 상품 식별
  productId   String // 등록상품ID
  optionId    String // 옵션ID
  skuId       String? // SKU ID
  productName String
  optionName  String?
  category    String?

  // 재고 (inventory_health)
  availableStock     Int? // 판매가능재고
  inboundStock       Int? // 입고예정재고
  productGrade       String? // 상품등급 (NEW 등)
  restockQty         Int? // 추가입고 추천수량
  restockDate        String? // 추가입고날짜
  estimatedDepletion String? // 재고예상 소진일
  storageFee         Int? // 이번달 누적보관료
  isItemWinner       Boolean? // 아이템위너 여부
  returns30d         Int? // 고객반품 30일

  // 매출/판매
  revenue7d   Decimal? @db.Decimal(18, 2)
  revenue30d  Decimal? @db.Decimal(18, 2)
  salesQty7d  Int?
  salesQty30d Int?
  orderCount  Int? // VENDOR_ITEM_METRICS '주문' 컬럼

  // vendor_item_metrics 전용
  fulfillmentType String? // 판매방식: "로켓그로스" | "판매자배송"
  visitors        Int?
  views           Int?
  cartAdds        Int?
  conversionRate  Decimal? @db.Decimal(10, 4) // 구매전환율 %
  itemWinnerRate  Decimal? @db.Decimal(10, 4) // 아이템위너 비율 %
  totalRevenue    Decimal? @db.Decimal(18, 2)
  totalSales      Int?
  totalCancelAmt  Decimal? @db.Decimal(18, 2)
  totalCancelled  Int?

  // 보관기간별 재고
  stock1to30d    Int?
  stock31to45d   Int?
  stock46to60d   Int?
  stock61to120d  Int?
  stock121to180d Int?
  stock181plusD  Int?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadId  String
  upload    InventoryUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, snapshotDate, productId, optionId, fileType])
  @@index([workspaceId, snapshotDate])
  @@index([workspaceId, productName])
}

// 재고 관리 제외 옵션
model InventoryExcludedProduct {
  id          String   @id @default(cuid())
  workspaceId String
  productId   String
  optionId    String
  excludedAt  DateTime @default(now())
  reason      String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, optionId])
  @@index([workspaceId])
}

// 재고 분석 결과
model InventoryAnalysis {
  id           String   @id @default(cuid())
  workspaceId  String
  snapshotDate DateTime
  analysedAt   DateTime @default(now())
  triggeredBy  String   @default("manual")

  results          Json
  shortageCount    Int  @default(0)
  returnRateCount  Int  @default(0)
  storageFeeCount  Int  @default(0)
  winnerIssueCount Int  @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, analysedAt(sort: Desc)])
}

// ─── 통합 재고 관리 (Inv) ─────────────────────────────────────────────────────

enum InvMovementType {
  INBOUND
  OUTBOUND
  RETURN
  TRANSFER
  ADJUSTMENT
}

enum InvReconciliationStatus {
  PENDING
  PARTIAL
  APPLIED
  CONFIRMED
  CANCELLED
}

enum InvStorageLocationType {
  OWN
  THIRD_PARTY
  STORE
}

// 상품 그룹 (카테고리)
model InvProductGroup {
  id      String @id @default(cuid())
  spaceId String
  name    String

  space    Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  products InvProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 상품 (옵션 단위로 관리)
model InvProduct {
  id      String           @id @default(cuid())
  spaceId String
  name    String // 공식 상품명 — 판매채널 노출명 (필수)
  code    String? // 상품 코드 (space 내 unique, null 허용)
  groupId String // 카테고리 필수 (non-null)
  status  InvProductStatus @default(ACTIVE)

  // 셀러 허브 확장 필드 (모두 nullable)
  brandId            String?
  internalName       String? // 관리 상품명 — 내부 식별용. 비어있으면 표시 시 name으로 fallback
  nameEn             String?
  manufacturer       String?
  manufactureCountry String?
  manufactureDate    DateTime?
  features           Json?
  certifications     Json?
  msrp               Decimal?  @db.Decimal(18, 2)
  description        String?
  optionAttributes   Json? // 예: [{name:"사이즈",values:["S","M","L"]}]

  // 발주 라운딩 단위 (10 = 10단위 라운딩, 100 = 100단위 등)
  reorderRoundUnit Int @default(10)

  space            Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  group            InvProductGroup    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  brand            Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  options          InvProductOption[]
  reorderConfig    InvReorderConfig?
  reorderPlanItems ReorderPlanItem[]
  reorderPlans     ReorderPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, code])
  @@index([spaceId])
  @@index([groupId])
  @@index([brandId])
}

// 상품 옵션
model InvProductOption {
  id        String  @id @default(cuid())
  productId String
  name      String
  sku       String?

  // 셀러 허브 확장 필드 (모두 nullable)
  costPrice       Decimal? @db.Decimal(18, 2)
  retailPrice     Decimal? @db.Decimal(18, 2)
  sizeLabel       String?
  setSizeLabel    String?
  attributeValues Json? // 예: {"사이즈":"S","색상":"파랑"}

  // 안전재고 (옵션 단위 단일 진입점) — 재고 상태 판정에 사용
  safetyStockQty Int @default(0)

  // 소프트삭제: 생산 차수·발주 등 연결 기록이 있는 옵션을 삭제할 때 row를 남겨 값을 보존한다.
  // 연결이 없으면 완전삭제, 있으면 deletedAt만 채운다. 목록/피커는 deletedAt: null로 필터.
  deletedAt DateTime?

  product              InvProduct                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements            InvMovement[]
  stockLevels          InvStockLevel[]
  locationMappingItems InvLocationProductMapItem[]
  productionRunItems   ProductionRunItem[]
  pricingScenarioItems PricingScenarioItem[]
  delOrderItems        DelOrderItem[]
  channelAliases       ChannelProductAlias[]
  aliasFulfillments    ChannelProductAliasFulfillment[]
  shippingLabels       DelShippingMethodLabel[]
  listingItems         ProductListingItem[]
  fulfillments         DelOrderItemFulfillment[]
  reorderPlanItems     ReorderPlanItem[]
  reorderAccuracies    ReorderPlanAccuracy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([deletedAt])
}

// 보관 장소
model InvStorageLocation {
  id       String                 @id @default(cuid())
  spaceId  String
  name     String
  type     InvStorageLocationType @default(OWN)
  isActive Boolean                @default(true)

  // 외부 데이터 소스 자동 연결 (예: 쿠팡 로켓그로스 자동 분배 대상 위치)
  // 값 예: 'coupang_rocket_growth'. 한 space 안에서 동일 source는 1개 위치만 가능.
  externalSource         String?
  externalIntegrationKey String?

  space                 Space                   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  stockLevels           InvStockLevel[]
  movements             InvMovement[]           @relation("MovementLocation")
  incomingTransfers     InvMovement[]           @relation("MovementToLocation")
  locationMappings      InvLocationProductMap[]
  reconciliations       InvReconciliation[]
  settingsDefault       InvSettings[]           @relation("DefaultLocation")
  productionRunStockIns ProductionRun[]         @relation("ProductionRunStockInLocation")
  reorderPlans          ReorderPlan[] // 연동위치 세트 발주 계획의 대상 위치

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, externalSource])
  @@index([spaceId])
  @@index([spaceId, type])
}

// 재고 이동 원장 (불변 레코드)
model InvMovement {
  id         String @id @default(cuid())
  spaceId    String
  optionId   String
  locationId String

  toLocationId    String? // TRANSFER 전용
  channelId       String? // OUTBOUND 전용 (셀러 허브 공용 Channel FK)
  type            InvMovementType
  quantity        Int
  movementDate    DateTime
  orderDate       DateTime? // OUTBOUND 전용
  reason          String? // ADJUSTMENT 시 필수 (앱 레벨 검증)
  referenceId     String? // 연관 이동 또는 조정 ID (import 멱등: import:dh:<contentHash>)
  importHistoryId String?
  delBatchId      String? // 배송 이력 이전으로 생성된 경우 출처 묶음. 묶음 삭제 시 cascade.

  space         Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  option        InvProductOption    @relation(fields: [optionId], references: [id], onDelete: Cascade)
  location      InvStorageLocation  @relation("MovementLocation", fields: [locationId], references: [id], onDelete: Cascade)
  toLocation    InvStorageLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  channel       Channel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  importHistory InvImportHistory?   @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)
  delBatch      DelBatch?           @relation(fields: [delBatchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([optionId])
  @@index([locationId])
  @@index([spaceId, movementDate])
  @@index([delBatchId])
}

// 현재 재고 수준 (옵션 × 장소)
model InvStockLevel {
  id         String @id @default(cuid())
  spaceId    String
  optionId   String
  locationId String
  quantity   Int    @default(0) // 음수 가능

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  option   InvProductOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([optionId, locationId])
  @@index([spaceId])
}

// 상품별 발주 예측 설정 — 한 상품의 모든 옵션이 동일한 리드타임/분석기간을 공유.
// 안전재고는 옵션 단위(InvProductOption.safetyStockQty)에서 관리한다.
model InvReorderConfig {
  id                 String @id @default(cuid())
  productId          String @unique
  leadTimeDays       Int    @default(7)
  analysisWindowDays Int    @default(90)

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// 대량 가져오기 이력
model InvImportHistory {
  id          String @id @default(cuid())
  spaceId     String
  fileName    String
  fileType    String // "EXCEL" | "CSV"
  totalRows   Int
  successRows Int
  errorRows   Int
  errors      Json? // 행 단위 에러 상세

  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  movements InvMovement[]

  importedAt DateTime @default(now())

  @@index([spaceId])
}

// 파일 기반 재고 대사 이력
model InvReconciliation {
  id            String                  @id @default(cuid())
  spaceId       String
  locationId    String
  fileName      String
  snapshotDate  DateTime
  status        InvReconciliationStatus @default(PENDING)
  matchResults  Json // 매칭/차이 상세
  totalItems    Int
  matchedItems  Int
  adjustedItems Int                     @default(0)

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([spaceId])
}

// 보관 장소별 외부 상품 코드 매핑 (1:N — 외부코드 1개 → 내부 옵션 N개)
model InvLocationProductMap {
  id         String @id @default(cuid())
  spaceId    String
  locationId String

  externalCode       String // 보관 장소의 상품 코드/ID
  externalName       String? // 보관 장소의 상품명 (참조용)
  externalOptionName String? // 보관 장소의 옵션명 (참조용)

  items InvLocationProductMapItem[]

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([locationId, externalCode])
  @@index([spaceId])
}

// 매핑 아이템 — 외부코드 하나에 여러 내부 옵션 + 수량 비율
model InvLocationProductMapItem {
  id       String @id @default(cuid())
  mapId    String
  optionId String
  quantity Int    @default(1)

  map    InvLocationProductMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  option InvProductOption      @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([mapId, optionId])
  @@index([optionId])
}

// 공간별 재고 덱 설정
model InvSettings {
  id                String  @id @default(cuid())
  spaceId           String  @unique
  defaultLocationId String?
  slackWebhookUrl   String?
  preferences       Json    @default("{}")

  space           Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  defaultLocation InvStorageLocation? @relation("DefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)

  @@index([spaceId])
}

// ─── 통합 배송 관리 (Del) ─────────────────────────────────────────────────────

enum DelBatchStatus {
  DRAFT
  COMPLETED
}

// 배치 출처 — 수동 등록 vs 과거 이력 이전(import).
// IMPORT 묶음은 재고를 차감하지 않는 과거 이력이며,
// 미래에 "완료→OUTBOUND 자동생성" 연동이 추가되어도 재처리 대상에서 제외해야 한다.
enum DelBatchSource {
  MANUAL
  IMPORT
}

// 배송 방식 (택배사 + 파일 포맷)
model DelShippingMethod {
  id               String  @id @default(cuid())
  spaceId          String
  name             String
  isActive         Boolean @default(true)
  formatConfig     Json // DelFormatColumn[] — 배송 파일 컬럼 매핑
  labelColumns     Json    @default("[]") // string[] — 활성화된 DelFieldMapping 키 (max 3). 배송 파일 생성 시 이 컬럼만 옵션별 값으로 덮어씀.
  defaultSplitMode String  @default("order") // 'order' | 'option' — 배송 파일 생성 시 기본 분할 모드

  space         Space                    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  orders        DelOrder[]
  productLabels DelShippingMethodLabel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 배송 방식 × 옵션별 필드 오버라이드 (배송 파일 생성 시 적용)
model DelShippingMethodLabel {
  id               String @id @default(cuid())
  spaceId          String
  shippingMethodId String
  optionId         String
  overrides        Json // { [field: DelFieldMapping]: string }

  space          Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  shippingMethod DelShippingMethod @relation(fields: [shippingMethodId], references: [id], onDelete: Cascade)
  option         InvProductOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shippingMethodId, optionId])
  @@index([spaceId])
  @@index([optionId])
}

// 배송 배치 (한 번의 배송 등록 작업 단위)
model DelBatch {
  id      String         @id @default(cuid())
  spaceId String
  status  DelBatchStatus @default(DRAFT)
  source  DelBatchSource @default(MANUAL)
  label   String?

  space          Space                  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  orders         DelOrder[]
  movements      InvMovement[] // 이력 이전(IMPORT) 시 생성된 OUTBOUND. 묶음 삭제 시 cascade.
  stockMovements ChannelStockMovement[] // 완료(출고) 시 차감된 채널 재고 이력. 묶음 삭제 시 cascade.

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([spaceId])
  @@index([spaceId, status])
  @@index([spaceId, source])
}

// 개별 주문 (배송 등록 행 1개)
model DelOrder {
  id               String  @id @default(cuid())
  spaceId          String
  batchId          String
  shippingMethodId String?
  channelId        String? // 셀러 허브 공용 Channel FK

  // PII 암호화 필드
  recipientNameEnc String
  recipientNameIv  String
  phoneEnc         String
  phoneIv          String
  addressEnc       String
  addressIv        String
  postalCode       String? // 우편번호 (비PII)
  deliveryMessage  String?
  memo             String? // 사용자 메모

  // 주문 메타
  orderDate     DateTime
  orderNumber   String?
  paymentAmount Decimal? @db.Decimal(18, 2)

  space          Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  batch          DelBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  shippingMethod DelShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  channel        Channel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items          DelOrderItem[]

  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([batchId])
  @@index([spaceId, orderDate])
}

// 주문 상품 (max 10, 앱 레벨 검증)
model DelOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  name      String // 원본 텍스트 — 미매칭 fallback 및 감사용
  quantity  Int
  optionId  String? // 단일 옵션 매칭 — InvProductOption.id (listingId와 상호 배타)
  listingId String? // 판매채널 상품(ProductListing) 매칭 — fulfillments로 실제 출고 옵션·수량 팬아웃

  order        DelOrder                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  option       InvProductOption?         @relation(fields: [optionId], references: [id], onDelete: SetNull)
  listing      ProductListing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  fulfillments DelOrderItemFulfillment[]

  @@index([orderId])
  @@index([optionId])
  @@index([listingId])
}

// 채널별 상품 별칭 사전 — 원본 상품명을 판매채널 상품(listing) 또는 단일 옵션에 매핑.
// optionId 또는 listingId 중 하나가 필수 (CHECK 제약으로 보장).
// 매칭 우선순위: listingId 있으면 listing, 아니면 optionId.
model ChannelProductAlias {
  id        String  @id @default(cuid())
  spaceId   String
  channelId String
  aliasName String // 정규화된 원본 상품명 (normalizeAlias 출력)
  optionId  String?
  listingId String?
  // multi-target 수동 매칭: fulfillments가 있으면 listingId·optionId 대신 사용
  // (우선순위: fulfillments[] > listingId > optionId)

  space        Space                            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel      Channel                          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  option       InvProductOption?                @relation(fields: [optionId], references: [id], onDelete: Cascade)
  listing      ProductListing?                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fulfillments ChannelProductAliasFulfillment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, aliasName])
  @@index([spaceId])
  @@index([optionId])
  @@index([listingId])
}

// 수동 매칭 alias의 다중 fulfillment 자식 테이블.
// 한 raw name이 여러 (옵션, 수량)으로 팬아웃되는 경우(예: "블랙 2 + 화이트 1") 사용.
// quantity 의미: "1 주문당 perSet 수량" — import 시점에 orderItem.quantity 곱해져 실제 출고 수량 산출.
model ChannelProductAliasFulfillment {
  id       String @id @default(cuid())
  aliasId  String
  optionId String
  quantity Int

  alias  ChannelProductAlias @relation(fields: [aliasId], references: [id], onDelete: Cascade)
  option InvProductOption    @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@index([aliasId])
  @@index([optionId])
}

// 컬럼 매핑 프리셋 (업로드 시 header name → field 매핑을 저장)
model DelColumnMappingPreset {
  id                  String  @id @default(cuid())
  spaceId             String
  name                String
  mapping             Json // Array<{ headerName: string; field: string }>
  channelId           String? // 프리셋 적용 시 배송 등록의 판매채널로 자동 입력될 채널
  paymentIsOrderTotal Boolean @default(false) // 결제금액이 "주문 총액"(행마다 반복)이면 import 시 행 합산 안 함

  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel Channel? @relation("PresetChannel", fields: [channelId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([channelId])
}

// 데이터 연동 이력
model DelIntegrationHistory {
  id          String   @id @default(cuid())
  spaceId     String
  type        String // "SALES" | "INVENTORY"
  dateFrom    DateTime
  dateTo      DateTime
  totalOrders Int
  movementIds String[]

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([spaceId])
}

// ─── 셀러 허브 공용 모델 ──────────────────────────────────────────────────────

// 브랜드 (상품에 연결, Space 단위)
model Brand {
  id      String  @id @default(cuid())
  spaceId String
  name    String
  logoUrl String?
  memo    String?

  space          Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  products       InvProduct[]
  productionRuns ProductionRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 채널 유형 정의 (사용자 정의 가능, 시스템 시드 포함)
// isSalesChannel=false 면 이 유형의 채널을 통한 출고가 InvMovement TRANSFER로 처리됨
model ChannelTypeDef {
  id             String   @id @default(cuid())
  spaceId        String
  name           String // 예: "B2C", "B2B", "내부 이관", "견본 발송"
  isSalesChannel Boolean  @default(true)
  isSystem       Boolean  @default(false) // 시스템 시드 — 삭제 차단
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channels Channel[]

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 공용 판매 채널
model Channel {
  id                      String   @id @default(cuid())
  spaceId                 String
  channelTypeDefId        String? // 마이그레이션 후 NOT NULL로 강제하기 전까지 nullable
  name                    String
  // 외부 데이터 소스 (예: 'coupang_rocket_growth'). 재고 위치(InvStorageLocation)와 동일
  // 패턴 — 위치·채널이 같은 외부 출처를 가리키고, 공간당 소스별 1개만 연결(1:1 페어링).
  // null = 통합재고 채널(판매자 직접 배송, 채널 재고 차감 관리).
  // non-null = 채널 자체 배송(연동) — 마켓 풀필먼트가 배송, 연동 데이터만 표시.
  externalSource          String?
  // 채널 자체 배송(연동) 채널이 가리키는 대표 채널(통합재고). null이면 대표/일반 채널.
  // 연동 채널의 판매채널 상품 화면은 대표 채널 상품을 읽기전용으로 미러링한다.
  representativeChannelId String?
  isActive                Boolean  @default(true)
  useSimulation           Boolean  @default(true) // 가격 시뮬레이션 노출/필수입력 결정
  adminUrl                String?
  freeShipping            Boolean  @default(false)
  freeShippingThreshold   Decimal? @db.Decimal(18, 2) // 무료배송 최소 주문금액
  usesMarketingBudget     Boolean  @default(false)
  applyAdCost             Boolean  @default(false) // 시뮬레이션 시 광고비 자동 적용
  shippingFee             Decimal? @db.Decimal(18, 2)
  vatIncludedInFee        Boolean  @default(true)
  paymentFeeIncluded      Boolean  @default(true) // 결제 수수료 포함 여부
  paymentFeePct           Decimal? @db.Decimal(6, 4) // 결제 수수료율 (0~1)
  requireOrderNumber      Boolean  @default(true)
  requirePayment          Boolean  @default(true)
  requireProducts         Boolean  @default(true)
  sortOrder               Int      @default(0) // 사용자 정의 정렬 순서 (오름차순, 동률은 name asc)

  space                   Space                    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channelTypeDef          ChannelTypeDef?          @relation(fields: [channelTypeDefId], references: [id], onDelete: Restrict)
  representativeChannel   Channel?                 @relation("ChannelRep", fields: [representativeChannelId], references: [id], onDelete: SetNull)
  fulfillmentChannels     Channel[]                @relation("ChannelRep")
  feeRates                ChannelFeeRate[]
  invMovements            InvMovement[]
  delOrders               DelOrder[]
  columnMappingPresets    DelColumnMappingPreset[] @relation("PresetChannel")
  productAliases          ChannelProductAlias[]
  productListings         ProductListing[]
  channelProducts         ChannelProduct[]
  pricingScenarios        PricingScenario[]
  pricingScenarioChannels PricingScenarioChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@unique([spaceId, externalSource]) // 외부 소스별 1개 채널만 (NULL 다중 허용)
  @@index([spaceId])
  @@index([channelTypeDefId])
  @@index([representativeChannelId])
}

// 채널별 카테고리 수수료율
// '기본'은 시스템 보장 카테고리 (모든 채널에 항상 1건 존재)
// VAT 포함 여부는 Channel.vatIncludedInFee로 통합 관리
model ChannelFeeRate {
  id           String  @id @default(cuid())
  channelId    String
  categoryName String
  ratePercent  Decimal @db.Decimal(6, 3)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, categoryName])
  @@index([channelId])
}

// 생산 차수 (Production Run) — 발주 단위. 여러 상품/옵션을 묶을 수 있음.
enum ProductionCostMode {
  TOTAL
  BREAKDOWN
}

enum ProductionRunStatus {
  PLANNED // 계획중
  ORDERED // 발주완료
  STOCKED_IN // 입고완료 (재고 입고까지 완료)
}

enum ProductionCostCategory {
  MATERIAL // 원자재
  LABOR // 인건비/봉제
  PACKAGING // 포장
  LOGISTICS // 물류
  OTHER // 기타
}

model ProductionRun {
  id                 String              @id @default(cuid())
  spaceId            String
  brandId            String? // 대표 브랜드 (선택). 없으면 multi-brand
  runNo              String // Space 단위 unique 차수 번호 (전체 범위)
  dueAt              DateTime? // 납기일 (선택)
  completedAt        DateTime? // 완료일 (선택, 레거시 — stockedInAt 과 동기화)
  orderedConfirmedAt DateTime? // 발주완료 전환 시점
  stockedInAt        DateTime? // 입고완료 전환 시점 (재고 INBOUND 반영 일자)
  stockInLocationId  String? // 입고완료 시 선택한 보관 위치
  status             ProductionRunStatus @default(PLANNED)
  totalCost          Decimal?            @db.Decimal(18, 2) // 총 생산원가 (TOTAL 모드: 직접 입력값 / BREAKDOWN 모드: costs 합계 캐시)
  costMode           ProductionCostMode  @default(TOTAL)
  memo               String?

  // 발주 계획 연계 (ReorderPlan.finalize 시 brandId별 분할 생성 가능 → 1:N)
  reorderPlanId String?

  space           Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  stockInLocation InvStorageLocation? @relation("ProductionRunStockInLocation", fields: [stockInLocationId], references: [id], onDelete: SetNull)
  reorderPlan     ReorderPlan?        @relation(fields: [reorderPlanId], references: [id], onDelete: SetNull)
  items           ProductionRunItem[]
  sets            ProductionRunSet[] // 세트 기반 차수의 세트별 라인 (옵션 items 는 분해 결과)
  costs           ProductionRunCost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, runNo])
  @@index([spaceId, orderedConfirmedAt])
  @@index([spaceId, status])
  @@index([brandId])
  @@index([reorderPlanId])
}

model ProductionRunItem {
  id           String @id @default(cuid())
  runId        String
  optionId     String
  quantity     Int // 발주 수량 (불변)
  stockedInQty Int? // 실제 입고 수량 (옵션별 분배 합). null = 입고완료 전. 0 이상 = 실입고

  run    ProductionRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  option InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([runId, optionId])
  @@index([optionId])
}

// 세트 기반 생산차수의 세트별 라인 — listing(=세트) 1개의 계획·입고 세트수량.
// 옵션별 ProductionRunItem 은 이 세트들을 ProductListingItem 으로 분해한 결과.
model ProductionRunSet {
  id              String @id @default(cuid())
  runId           String
  listingId       String
  listingName     String // 표시용 스냅샷 (listing 삭제/개명 대비)
  plannedSetQty   Int // 계획된 세트 수량
  stockedInSetQty Int? // 실제 입고된 세트 수량 합. null = 입고완료 전.

  run     ProductionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  listing ProductListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  @@unique([runId, listingId])
  @@index([listingId])
}

model ProductionRunCost {
  id          String                 @id @default(cuid())
  runId       String
  itemName    String // 비용 항목 (필수)
  description String? // 상세 내용
  category    ProductionCostCategory @default(OTHER) // 비용 분류
  spec        Decimal?               @db.Decimal(18, 4) // 규격 (선택)
  quantity    Decimal                @default(1) @db.Decimal(18, 4) // 수량 (필수, 기본 1)
  unitPrice   Decimal                @db.Decimal(18, 2) // 단가 (필수)
  amount      Decimal                @db.Decimal(18, 2) // (spec ?? 1) × quantity × unitPrice
  note        String?
  sortOrder   Int                    @default(0)

  run ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// 가격 시뮬레이션 시나리오
// 옵션 N개를 선택하고 채널/할인/비용 변수를 조합해 순수익을 계산하는 단위.
// 결과(netProfit, margin)는 캐시이므로 inputs 변경 시 재계산 후 갱신.
model PricingScenario {
  id                    String        @id @default(cuid())
  spaceId               String
  channelId             String? // 레거시 단일 채널 연결 (하위 호환 유지, 추후 제거)
  name                  String // 시나리오 이름
  memo                  String?
  // 시뮬레이션 전역 옵션
  includeVat            Boolean       @default(true) // 판매가에 VAT 포함 여부
  vatRate               Decimal       @default(0.1) @db.Decimal(6, 4) // 부가세율
  // 프로모션 설정
  promotionType         PromotionType @default(NONE)
  promotionValue        Decimal?      @db.Decimal(18, 4) // FLAT: 금액, PERCENT: 0~1 비율
  // 반품/교환 비용 반영
  applyReturnAdjustment Boolean       @default(false)

  space    Space                    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel  Channel?                 @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items    PricingScenarioItem[]
  channels PricingScenarioChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, updatedAt])
  @@index([channelId])
}

// 시나리오 ↔ 채널 M-N 조인 테이블
model PricingScenarioChannel {
  id         String @id @default(cuid())
  scenarioId String
  channelId  String
  sortOrder  Int    @default(0)

  scenario PricingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  channel  Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, channelId])
  @@index([scenarioId])
  @@index([channelId])
}

// 시나리오 안의 옵션별 entry — 옵션마다 독립적인 가격/원가/비용 변수와 결과 캐시
model PricingScenarioItem {
  id         String  @id @default(cuid())
  scenarioId String
  optionId   String? // nullable — 수동 입력 행(manualName 사용)은 null 허용

  // 수동 입력 행 (optionId가 null일 때 사용)
  manualName      String? // 상품명 직접 입력
  manualBrandName String? // 브랜드명 직접 입력
  unitsPerSet     Int     @default(1) // 세트당 단위 수량 (기본 1)

  // 입력 변수 — 모두 nullable이면 시뮬레이션 시점에 옵션·채널·설정에서 자동 채움
  costPrice        Decimal? @db.Decimal(18, 2) // 원가 (없으면 InvProductOption.costPrice → 사용자 직접)
  salePrice        Decimal  @db.Decimal(18, 2) // 사용자 입력 판매가
  discountRate     Decimal  @default(0) @db.Decimal(6, 4) // 0~1 (예: 0.1 = 10% 할인)
  channelFeePct    Decimal  @default(0) @db.Decimal(6, 4) // 채널 수수료율 (0~1)
  shippingCost     Decimal  @default(0) @db.Decimal(18, 2) // 옵션당 배송비
  packagingCost    Decimal  @default(0) @db.Decimal(18, 2)
  adCostPct        Decimal  @default(0) @db.Decimal(6, 4)
  operatingCostPct Decimal  @default(0) @db.Decimal(6, 4)

  // 결과 캐시 (서버에서 계산해 저장)
  finalPrice   Decimal @default(0) @db.Decimal(18, 2) // salePrice × (1 - discountRate)
  revenueExVat Decimal @default(0) @db.Decimal(18, 2)
  totalCost    Decimal @default(0) @db.Decimal(18, 2) // costPrice + 모든 비용
  netProfit    Decimal @default(0) @db.Decimal(18, 2)
  margin       Decimal @default(0) @db.Decimal(6, 4) // netProfit / revenueExVat

  sortOrder Int @default(0)

  scenario PricingScenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  option   InvProductOption? @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@index([scenarioId])
  @@index([optionId])
}

// Space 단위 가격 시뮬레이션 기본값
model ProductPricingSettings {
  id                      String  @id @default(cuid())
  spaceId                 String  @unique
  // 기존 필드 (0~100 % 단위 유지)
  defaultOperatingCostPct Decimal @default(0) @db.Decimal(6, 3)
  defaultAdCostPct        Decimal @default(0) @db.Decimal(6, 3)
  defaultPackagingCost    Decimal @default(0) @db.Decimal(18, 2)
  // 신규 필드 (0~1 비율 단위)
  defaultChannelFeePct    Decimal @default(0) @db.Decimal(6, 4) // 기본 채널 수수료율
  defaultShippingCost     Decimal @default(0) @db.Decimal(18, 2) // 기본 배송비
  defaultReturnRate       Decimal @default(0) @db.Decimal(6, 4) // 기본 반품율 (0~1)
  defaultReturnShipping   Decimal @default(0) @db.Decimal(18, 2) // 반품 건당 배송비
  // VAT (가격 시뮬레이터 공통 — 시나리오별 VAT 대체)
  defaultIncludeVat       Boolean @default(true) // VAT 포함 여부
  defaultVatRate          Decimal @default(0.1) @db.Decimal(6, 4) // VAT 율 (0~1)
  autoApplyChannelFee     Boolean @default(false) // 채널 수수료 자동 적용
  autoApplyAdCost         Boolean @default(false) // 광고비 자동 적용
  autoApplyShipping       Boolean @default(false) // 배송비 자동 적용
  // 마진 등급 임계값 — 단일 기준 (사용자가 설정 페이지에서 조정 가능)
  platformTargetGood      Decimal @default(0.25) @db.Decimal(5, 4) // '높음' 임계
  platformTargetFair      Decimal @default(0.15) @db.Decimal(5, 4) // '적합' 하한
  minimumAcceptableMargin Decimal @default(0.10) @db.Decimal(5, 4) // 최소 허용 마진 (할인 한계 계산용)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Space별 옵션 값-코드 자동 학습 사전
// 사용자가 상품 저장 시 속성 값의 코드를 수정하면 여기에 자동 upsert되고,
// 다음 상품 생성 시 에디터가 자동 제안한다 (Space 격리 + 시스템 사전보다 우선).
model SpaceOptionCodeAlias {
  id            String @id @default(cuid())
  spaceId       String
  attributeName String // "사이즈", "색상", "재질" ...
  value         String // "누드", "블랙" ...
  code          String // "NDE", "BLK" ... 사용자 커스텀 축약

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, attributeName, value])
  @@index([spaceId])
}

// ─── 판매채널 상품 (ProductListing) ─────────────────────────────────────────────
// 채널별로 상품을 묶음 단위(N개 옵션 × 수량)로 구성해 전용 상품명·키워드·판매가로 노출.
// 배송 업로드 매칭의 기본 단위 — 한 listing은 여러 fulfillment(실제 출고 옵션·수량)로 펼쳐진다.

model ProductListing {
  id               String               @id @default(cuid())
  spaceId          String
  channelId        String
  channelProductId String? // 채널상품(ChannelProduct) 귀속 — null이면 단독 listing
  internalCode     String? // 사용자 관리용 식별자 (선택)
  searchName       String // 상품명(검색용) — 채널 리스팅 상단 노출
  displayName      String // 상품명(노출용) — 상세 페이지 타이틀
  managementName   String? // 상품명(관리용) — 내부 목록 표시 (없으면 searchName fallback)
  keywords         Json                 @default("[]") // string[] — 사용자 확정 키워드
  retailPrice      Decimal?             @db.Decimal(18, 2) // 판매가격 (소비자가는 구성품에서 자동 계산)
  // 채널 재고 (세트 단위) — 차감형 잔량.
  // null이면 기능 off: 채널-품절 판정·자동 차감 모두 안 함 (가용재고만으로 판정).
  // 값이 있으면 MANUAL 배치 완료(출고) 시 DelOrderItem.quantity만큼 자동 차감.
  // 차감만 존재 — 입고/증가 조정은 사용자가 수동으로 한다. 음수 허용(오버셀 진실 반영).
  channelStock     Int?
  status           ProductListingStatus @default(ACTIVE)
  memo             String?

  space             Space                  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel           Channel                @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelProduct    ChannelProduct?        @relation(fields: [channelProductId], references: [id], onDelete: SetNull)
  items             ProductListingItem[]
  aliases           ChannelProductAlias[]
  delItems          DelOrderItem[]
  stockMovements    ChannelStockMovement[]
  reorderPlanSets   ReorderPlanSet[] // 세트 발주 계획에서 이 listing(=세트)을 참조
  productionRunSets ProductionRunSet[] // 세트 생산차수에서 이 listing(=세트)을 참조

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // unique 제약 없음 — listing 식별은 옵션 구성으로 이루어지며, 이름은 표시용. 같은 cp 안에서도 동일 이름 허용.
  @@index([spaceId, channelId])
  @@index([status])
  @@index([channelProductId])
}

// 판매채널 상품의 구성 옵션 (InvProductOption × 수량)
model ProductListingItem {
  id        String @id @default(cuid())
  listingId String
  optionId  String
  quantity  Int // 묶음 내 수량 (세트면 2, 3 등)
  sortOrder Int    @default(0)

  listing ProductListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  option  InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([listingId, optionId])
  @@index([optionId])
}

// 채널 재고 차감 이력(원장).
// MANUAL 배치 완료(출고) 시 listingId 매칭된 DelOrderItem 라인마다 1 레코드 생성.
// @@unique([batchId, orderItemId])로 멱등성 보장 — 재완료 시 중복 차감 방지 + 감사 추적.
// 차감만 기록하며 입고/복원은 없음(배치 삭제 시 cascade로 행은 삭제되나 잔량은 유지).
model ChannelStockMovement {
  id          String   @id @default(cuid())
  spaceId     String
  listingId   String
  batchId     String // 차감을 유발한 배송 묶음
  orderItemId String // 멱등 키 구성 — 출고 라인당 1 레코드
  quantity    Int // 차감량 = DelOrderItem.quantity (세트 단위, 양수)
  createdAt   DateTime @default(now())

  space   Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  listing ProductListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  batch   DelBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, orderItemId])
  @@index([spaceId])
  @@index([listingId])
  @@index([batchId])
}

// 배송 주문 아이템의 실제 출고 단위 — listing 매칭이면 1:N, 단일 옵션이면 비어있음
model DelOrderItemFulfillment {
  id          String @id @default(cuid())
  orderItemId String
  optionId    String
  quantity    Int // listingItem.quantity × orderItem.quantity

  orderItem DelOrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([optionId])
}

// 채널상품 — channel 단위 판매 묶음의 실체 엔티티.
// 혼합 구성(여러 product 옵션 묶음) listing도 지원.
// 자식 ProductListing들은 channelProductId FK로 귀속됨.
model ChannelProduct {
  id        String @id @default(cuid())
  spaceId   String
  channelId String

  baseSearchName     String
  baseDisplayName    String?
  baseManagementName String?
  baseInternalCode   String?
  memo               String?
  keywords           Json    @default("[]") // string[]

  space    Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel  Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  listings ProductListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, channelId])
}

// ─── Sales Content Deck (정보 세팅) ───────────────────────────────────────────

model Product {
  id            String  @id @default(cuid())
  spaceId       String
  name          String
  oneLinerPitch String? // 한 줄 가치 제안
  customFields  Json    @default("[]") // [{ key: string, value: string }]
  isActive      Boolean @default(true)

  space     Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  personas  ProductPersona[]
  ideations IdeationProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// Product ↔ Persona 다대다 매핑.
model ProductPersona {
  productId String
  personaId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([productId, personaId])
  @@index([productId])
  @@index([personaId])
}

model Persona {
  id           String  @id @default(cuid())
  spaceId      String
  name         String
  jobTitle     String?
  industry     String?
  customFields Json    @default("[]") // [{ key: string, value: string }]
  isActive     Boolean @default(true)

  space     Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  ideations Ideation[]
  products  ProductPersona[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

model BrandProfile {
  id               String  @id @default(cuid())
  spaceId          String  @unique
  companyName      String
  shortDescription String?
  toneOfVoice      Json? // string[] (최대 3개)
  customFields     Json    @default("[]") // [{ key: string, value: string }]

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Sales Content Deck (AI 어댑터) ───────────────────────────────────────────

enum AiGenerationStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// Space(워크스페이스) 월간 AI 이미지 크레딧 — (spaceId, yearMonth) 단위로 카운터.
// atomic UPDATE ... WHERE imageUsed < imageQuota 로 동시성 안전하게 예약.
model WorkspaceAiCredit {
  id         String @id @default(cuid())
  spaceId    String
  yearMonth  String // "YYYY-MM"
  imageUsed  Int    @default(0)
  imageQuota Int    @default(50)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, yearMonth])
  @@index([spaceId])
}

// 이미지 생성 이력. reservationId 반환용 id.
model ImageGenerationLog {
  id             String             @id @default(cuid())
  spaceId        String
  userId         String?
  provider       String // 'gemini-imagen' 등
  model          String // 'imagen-4.0-generate-001' 등
  prompt         String
  negativePrompt String?
  aspectRatio    String?
  status         AiGenerationStatus @default(PENDING)
  outputCount    Int                @default(0)
  creditMonth    String? // 연결된 WorkspaceAiCredit.yearMonth — refund 판단용
  errorCode      String?
  errorMessage   String?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, createdAt])
  @@index([status])
}

// 텍스트 생성 이력. Claude Code ACP / Ollama.
model TextGenerationLog {
  id             String             @id @default(cuid())
  spaceId        String
  userId         String?
  provider       String // 'claude-code-acp' | 'ollama'
  model          String? // 모델명(Ollama) 혹은 null(ACP)
  responseFormat String? // 'text' | 'json'
  status         AiGenerationStatus @default(PENDING)
  contentPreview String? // 응답 앞 500자 (감사/디버그용)
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  errorCode      String?
  errorMessage   String?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([spaceId, createdAt])
  @@index([status])
}

// ─── Sales Content Deck (템플릿 · 채널) ──────────────────────────────────────

enum TemplateKind {
  BLOG
  SOCIAL
  CARDNEWS
}

enum SalesContentPlatform {
  BLOG_NAVER
  BLOG_TISTORY
  BLOG_WORDPRESS
  THREADS
  X
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  YOUTUBE_SHORTS
  OTHER
}

enum SalesContentChannelKind {
  BLOG
  SOCIAL
}

enum PublisherMode {
  API
  BROWSER
  MANUAL
}

enum CollectorMode {
  API
  BROWSER
  MANUAL
  NONE
}

// 콘텐츠 템플릿. spaceId=null + isSystem=true 인 경우 모든 공간이 공유하는 시스템 템플릿.
// MVP-6 에서 채널별로 재설계 예정. 현재는 slug 제거된 minimal shape.
model Template {
  id       String       @id @default(cuid())
  spaceId  String? // null = 시스템 템플릿
  name     String
  kind     TemplateKind
  sections Json // kind=BLOG|SOCIAL: { sections: [...] }, kind=CARDNEWS: { slides: [...] }
  isSystem Boolean      @default(false)
  isActive Boolean      @default(true)

  space Space? @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([kind])
}

// 배포 채널 (블로그 · 소셜). seller-hub 의 Channel 과는 구분되는 별도 엔터티.
model SalesContentChannel {
  id            String                  @id @default(cuid())
  spaceId       String
  platform      SalesContentPlatform
  kind          SalesContentChannelKind
  name          String // 사용자 표기명
  platformSlug  String // utm_source 용 kebab
  publisherMode PublisherMode           @default(MANUAL)
  collectorMode CollectorMode           @default(MANUAL)
  isActive      Boolean                 @default(true)
  config        Json? // 채널별 구성 (blog base URL, API endpoint 등)

  space       Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  contents    Content[]
  deployments ContentDeployment[]
  credentials ChannelCredential[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, platformSlug])
  @@index([spaceId])
  @@index([platform])
}

// ─── Sales Content Deck (아이데이션) ─────────────────────────────────────────

enum IdeaGeneratedBy {
  USER
  AI
}

// ─── Sales Content Deck (콘텐츠 제작) ────────────────────────────────────────

enum ContentStatus {
  TODO // 신규 — 토픽만 선정된 상태 (본문 없음)
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ANALYZED
}

enum ContentAssetKind {
  IMAGE
  LINK
}

// 콘텐츠 1건. doc(Json) 은 TipTap Doc.
// 페르소나/상품 컨텍스트는 ideationId 로 lookup (denormalize 안 함).
model Content {
  id      String        @id @default(cuid())
  spaceId String
  userId  String? // 작성자
  title   String
  body    String? // raw markdown / textual representation
  doc     Json // TipTap doc
  status  ContentStatus @default(DRAFT)

  // SEO
  urlSlug         String?
  targetKeyword   String?
  relatedKeywords Json    @default("[]") // string[] (메타 태그)

  // origin
  ideationId String? // Ideation.id (FK 미설정 — 코드 레벨 lookup)
  ideaIndex  Int? // Ideation.ideas 의 인덱스

  // deploy
  channelId String? // 기본 배포 채널 (선택)

  // misc
  snapshotHash String? // 변경 감지용
  publishedAt  DateTime?
  scheduledAt  DateTime?

  space       Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel     SalesContentChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  assets      ContentAsset[]
  versions    ContentVersion[]
  deployments ContentDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([spaceId, createdAt])
  @@index([channelId])
}

// ─── Sales Content Deck (배포 · UTM · 클릭) ─────────────────────────────────

enum DeploymentStatus {
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
}

// 한 건의 Content 를 한 채널에 배포한 기록. shortSlug 은 /c/{slug} 리다이렉터 키.
model ContentDeployment {
  id           String           @id @default(cuid())
  spaceId      String
  contentId    String
  channelId    String
  shortSlug    String           @unique
  targetUrl    String // 최종 목적지 (상품/랜딩 페이지)
  platformUrl  String? // 실제 게시물 URL (Unit 10 에서 채움)
  status       DeploymentStatus @default(SCHEDULED)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  errorMessage String?

  space       Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  content     Content             @relation(fields: [contentId], references: [id], onDelete: Cascade)
  channel     SalesContentChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  clickEvents ContentClickEvent[]
  metrics     DeploymentMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([contentId])
  @@index([channelId])
}

// /c/{slug} 리다이렉터 진입 이벤트. ip 는 SHA-256 + salt 로 익명화.
model ContentClickEvent {
  id           String  @id @default(cuid())
  spaceId      String
  deploymentId String
  ipHash       String?
  userAgent    String?
  referrer     String?

  space      Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  deployment ContentDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([deploymentId, createdAt])
  @@index([spaceId, createdAt])
}

// ─── Sales Content Deck (자격증명 · 작업 큐) ────────────────────────────────

enum ChannelCredentialKind {
  COOKIE // Playwright storageState JSON
  OAUTH // access/refresh token 쌍
  API_KEY
}

model ChannelCredential {
  id               String                @id @default(cuid())
  spaceId          String
  channelId        String
  kind             ChannelCredentialKind
  encryptedPayload String // hex 인코딩 AES-256-CBC
  iv               String // hex iv
  expiresAt        DateTime?
  lastVerifiedAt   DateTime?
  lastError        String?

  space   Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel SalesContentChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, kind])
  @@index([spaceId])
}

enum SalesContentJobKind {
  PUBLISH
  COLLECT_METRIC
  INSIGHT_SWEEP
}

enum SalesContentJobStatus {
  PENDING
  CLAIMED
  COMPLETED
  FAILED
}

// ─── Sales Content Deck (성과 지표) ────────────────────────────────────────

enum MetricSource {
  MANUAL
  API
  BROWSER
  INTERNAL // /c/[slug] 자체 집계
}

// 배포 1건 × 일자 단위 성과 지표. Unit 11 수동 입력 + Unit 12 자동 수집 공통.
model DeploymentMetric {
  id             String       @id @default(cuid())
  spaceId        String
  deploymentId   String
  date           DateTime     @db.Date
  impressions    Int?
  views          Int?
  likes          Int?
  comments       Int?
  shares         Int?
  externalClicks Int? // 플랫폼 자체 집계 클릭 (내부 /c/[slug] 와 구분)
  source         MetricSource @default(MANUAL)

  space      Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  deployment ContentDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deploymentId, date, source])
  @@index([spaceId, date])
  @@index([deploymentId, date])
}

// DB-backed 작업 큐. 맥미니 워커가 주기 polling 해서 claim → 처리 → complete.
model SalesContentJob {
  id           String                @id @default(cuid())
  spaceId      String
  kind         SalesContentJobKind
  status       SalesContentJobStatus @default(PENDING)
  targetId     String? // deploymentId 등 대상 엔터티 id
  payload      Json? // kind 별 페이로드
  scheduledAt  DateTime              @default(now())
  claimedAt    DateTime?
  claimedBy    String? // 워커 instance id
  completedAt  DateTime?
  attempts     Int                   @default(0)
  errorMessage String?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([spaceId, status])
  @@index([kind, status])
}

// ─── Sales Content Deck (콘텐츠 버전 히스토리) ───────────────────────────────

// Content 수정 직전 상태를 스냅샷으로 보존. versionNumber 는 contentId 범위 내 1부터 증가.
model ContentVersion {
  id              String  @id @default(cuid())
  contentId       String
  spaceId         String
  versionNumber   Int // content 별 1부터 증가
  title           String
  doc             Json // 스냅샷 시점의 TipTap Doc
  snapshotHash    String? // 변경 감지용
  createdByUserId String? // 이 버전을 만든 사용자 (nullable — 시스템 생성 가능)
  note            String? // "자동 스냅샷 (PATCH)", "수동 저장", "롤백 from v3" 같은 메타

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contentId, versionNumber])
  @@index([contentId, createdAt])
  @@index([spaceId, createdAt])
}

// 콘텐츠 첨부 에셋 (이미지 · 링크). 이미지 URL 은 Unit 7 Supabase Storage 결과.
model ContentAsset {
  id          String           @id @default(cuid())
  spaceId     String
  contentId   String
  kind        ContentAssetKind
  slotKey     String? // TipTap 노드 key
  url         String
  title       String?
  alt         String?
  width       Int?
  height      Int?
  mimeType    String?
  storagePath String? // supabase path (이미지인 경우)

  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contentId])
  @@index([spaceId])
}

// 한 번의 아이데이션 실행 결과.
// 페르소나(필수) + 상품(다중 선택) + 타겟 키워드 → AI 호출 → ideas[] 결과.
// 개별 idea 를 Content 에서 참조할 때는 (ideationId, ideaIndex) 페어를 사용.
//
// ideas[] 의 각 element shape:
//   {
//     targetKeyword: string,
//     searchVolume: { naver?: { volume, fetchedAt }, google?: {...}, aiEstimate?: { volume, model } },
//     title: string,
//     outline: string,           // 또는 string[]
//     relatedKeywords: string[], // 메타 태그
//     urlSlug: string,           // SEO friendly slug
//   }
model Ideation {
  id              String          @id @default(cuid())
  spaceId         String
  userId          String? // 실행한 사용자
  personaId       String // 필수
  targetKeywords  Json            @default("[]") // string[]
  ideas           Json            @default("[]") // Idea[] (위 shape)
  generatedBy     IdeaGeneratedBy
  providerName    String?
  providerModel   String?
  latencyMs       Int?
  promptTraceHash String?
  ruleIdsSnapshot Json?

  space    Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  persona  Persona           @relation(fields: [personaId], references: [id], onDelete: Cascade)
  products IdeationProduct[]

  createdAt DateTime @default(now())

  @@index([spaceId, createdAt])
  @@index([personaId])
}

// Ideation ↔ Product 다대다.
model IdeationProduct {
  ideationId String
  productId  String

  ideation Ideation @relation(fields: [ideationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([ideationId, productId])
  @@index([ideationId])
  @@index([productId])
}

// ─── Sales Content Deck (개선 규칙 · 셀프-임프루빙) ──────────────────────────

enum RuleSource {
  USER
  AI
}

enum RuleStatus {
  PROPOSED
  ACTIVE
  ARCHIVED
}

enum RuleScope {
  WORKSPACE
  PRODUCT
  PERSONA
  CHANNEL
  COMBINATION
}

// 아이데이션·콘텐츠 생성 프롬프트에 주입될 개선 규칙.
// status=ACTIVE + scope 필터 매치 시 Unit 4 `loadActiveRules` 가 선택한다.
model ImprovementRule {
  id                    String     @id @default(cuid())
  spaceId               String
  scope                 RuleScope
  source                RuleSource @default(USER)
  status                RuleStatus @default(PROPOSED)
  title                 String
  body                  String
  weight                Int        @default(5)
  targetProductId       String?
  targetPersonaId       String?
  targetChannelId       String?
  evidenceDeploymentIds Json? // AI 생성 시 근거가 된 배포 id 배열

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([spaceId, scope, status])
}

// ─── 발주 예측 모델 ───────────────────────────────────────────────────────────

// 발주 계획 헤더 — 한 번의 발주 예측 작업 단위
model ReorderPlan {
  id          String            @id @default(cuid())
  spaceId     String
  planNo      String // Space 단위 unique 계획 번호
  status      ReorderPlanStatus @default(DRAFT)
  windowDays  Int // 예측 분석 기간 (일)
  createdById String
  productId   String? // 상품 단위 계획. null = 레거시 전체-계획 또는 연동위치 세트 계획
  // 연동 위치(예: 쿠팡 로켓그로스) 세트 기반 계획. 값이 있으면 세트 계획이며 productId 는 null.
  // productId·locationId 동시 non-null 금지(앱 레벨 검증).
  locationId  String?

  finalizedAt       DateTime? // (레거시) 확정 전환 시점 — confirmedAt 으로 대체 중
  confirmedAt       DateTime? // "예측 검증 시작" 시점 = 예측 동결점 = 신뢰도 평가 앵커
  biasAdjustApplied Json? // 적용된 bias 보정 계수 맵 { optionId: factor }

  totalSuggestedQty Int // 전체 옵션 제안 수량 합계
  totalFinalQty     Int // 전체 옵션 최종 확정 수량 합계
  memo              String?

  // revision 계보 — 확정건 수정은 same-row 변경이 아니라 revert→새 DRAFT revision 생성
  supersededAt       DateTime? // 이 계획이 revert되어 대체된 시점
  supersededByPlanId String? // 대체한 새 계획 id
  sourcePlanId       String? // 이 계획이 어느 확정 계획에서 revert되어 파생됐는지

  space     Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  product   InvProduct?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  location  InvStorageLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // self-relation: source(확정 원본) ← revisions(파생 초안)
  sourcePlan ReorderPlan?  @relation("PlanRevision", fields: [sourcePlanId], references: [id], onDelete: SetNull)
  revisions  ReorderPlan[] @relation("PlanRevision")

  items          ReorderPlanItem[]
  sets           ReorderPlanSet[] // 연동위치 세트 계획의 세트별 라인 (옵션 items 는 분해 결과)
  accuracies     ReorderPlanAccuracy[]
  productionRuns ProductionRun[] // "생산차수 생성" 액션으로 brandId별 분할 생성 가능 (1:N)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, planNo])
  @@index([spaceId, status])
  @@index([spaceId, productId])
  @@index([spaceId, locationId])
  @@index([spaceId, confirmedAt])
  @@index([sourcePlanId])
  @@index([createdById])
}

// 세트 기반 발주 계획의 세트별 라인 — listing(=세트) 1개의 제안·최종 세트수량.
// 옵션별 ReorderPlanItem 은 이 세트들을 ProductListingItem 으로 분해한 결과(공유 옵션은 Σ 합산).
model ReorderPlanSet {
  id              String @id @default(cuid())
  planId          String
  listingId       String
  listingName     String // 표시용 스냅샷
  currentSetStock Int // 계획 생성 시점 세트 가용재고(파이프라인) 스냅샷
  suggestedSetQty Int // 병목 환산 제안 세트수량
  finalSetQty     Int // 사용자 확정 세트수량
  sortOrder       Int    @default(0)

  plan    ReorderPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  listing ProductListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  @@unique([planId, listingId])
  @@index([listingId])
}

// 발주 계획 옵션별 라인 — 옵션 1개의 예측 결과 및 최종 수량
model ReorderPlanItem {
  id        String @id @default(cuid())
  planId    String
  optionId  String
  productId String

  currentStock        Int // 현재 재고 수량
  dailyAvgForecast    Decimal              @db.Decimal(18, 4) // 일평균 예측 소진량
  forecastModel       ReorderForecastModel // 사용된 예측 모델
  leadTimeDays        Int // 리드타임 (일)
  safetyStockQty      Int // 안전재고 수량
  suggestedQty        Int // 공식 계산 제안 수량
  roundedSuggestedQty Int // 라운딩 적용 후 제안 수량
  finalQty            Int // 사용자 확정 수량
  roundUnit           Int // 라운딩 단위 (10 or 100 등)

  rationale String? @db.Text // LLM 생성 근거 텍스트
  userNote  String? @db.Text // 사용자 입력 메모

  biasAdjustFactor Decimal  @db.Decimal(6, 4) // 적용된 bias 보정 계수 (1.0 = 보정 없음)
  confidenceScore  Decimal? @db.Decimal(6, 4) // 예측 신뢰도 (0~1, null = 미산출)
  inputsSnapshot   Json // 예측 재현 가능 입력값 스냅샷 (초안 생성 당시 입력)

  // 레이어드 발주(연동 세트 + 직접 배송) 전용 — 레이어별 GROSS(현재고·안전재고 차감 전, float).
  // 옵션 수요가 진실이므로 로켓/직접 raw GROSS를 각각 보관하고, 최종 = max(0, ceil(로켓+직접+safety−stock)).
  // 세트는 발주 옵션의 역산 표시(파생)일 뿐 이 값으로 되먹이지 않는다(중복 세트 과다집계 방지).
  // null = 비레이어드(일반 상품/위치 세트) 플랜.
  rocketGrossQty Decimal? @db.Decimal(18, 4)
  directGrossQty Decimal? @db.Decimal(18, 4)

  // "예측 검증 시작"(확정) 시점에 동결한 예측 스냅샷 — 신뢰도 측정의 단일 진실원.
  // null = 미확정. accuracy는 live 값이 아니라 이 동결값을 읽어야 사후 수정에 오염 안 됨.
  confirmedDailyAvgForecast Decimal?               @db.Decimal(18, 4)
  confirmedLeadTimeDays     Int?
  confirmedSafetyStockQty   Int?
  confirmedFinalQty         Int?
  snapshotSource            ReorderSnapshotSource? // LIVE(확정 시점) | BACKFILLED(마이그 근사)

  plan    ReorderPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  option  InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)
  product InvProduct       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([planId, optionId])
  @@index([planId])
  @@index([optionId])
}

// 발주 계획 적중률 결과 — 입고 후 실제 소진 vs 예측 비교
model ReorderPlanAccuracy {
  id       String @id @default(cuid())
  planId   String
  optionId String

  evaluatedAt DateTime // 적중률 계산 시점
  periodStart DateTime // 평가 기간 시작 (stockedInAt)
  periodEnd   DateTime // 평가 기간 종료 (stockedInAt + leadTimeDays)

  actualOutbound   Int // 실제 출고 수량
  forecastOutbound Decimal @db.Decimal(18, 4) // 예측 출고 수량 (dailyAvgForecast × leadTimeDays)

  wape Decimal @db.Decimal(10, 4) // WAPE (Weighted Absolute Percentage Error)
  bias Decimal @db.Decimal(10, 4) // Bias% = (forecast - actual) / actual (양수 = 과예측)

  stockoutDays  Int // 재고 소진 일수 (일별 잔량 시뮬레이션)
  overstockDays Int // 과잉재고 일수

  // revert/supersede 시 삭제 대신 무효화 — 학습/제안 집계는 ACTIVE만 사용
  validity         ReorderAccuracyValidity @default(ACTIVE)
  evaluationStatus ReorderEvaluationStatus @default(MEASURED) // 옵션별 평가 진행 상태
  // provenance — 이 계획 예측에 입력으로 쓰인 bias 출처(어느 정산 계획에서 학습됐는지)
  biasSourcePlanId String?

  plan   ReorderPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  option InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([planId, optionId])
  @@index([planId])
  @@index([optionId])
  @@index([validity])
}

// ─── 재무 관리 Deck (Finance) ─────────────────────────────────────────────────
// 현금주의(cash-basis) 모델. 은행/카드 거래내역 업로드 → 계정과목 분류 → 현금흐름·잔고·부채.

enum FinAccountKind {
  BANK
  CARD
}

enum FinCategoryType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  TRANSFER
}

// 손익 흐름도(현금흐름 상세 Sankey) 역할 — level-1 대분류에만 부여.
// 미태그 수입=기타수익, 미태그 지출=판매관리비(OPEX)로 취급.
enum FinFlowRole {
  MERCH_SALES // 상품매출 (매출총이익 = 상품매출 − 매출원가)
  COGS // 매출원가
  OPEX // 영업비용(판매관리비)
  FINANCING_COST // 금융비용
}

enum FinClassRuleMatchType {
  EXACT // 정정 학습 — 정규화된 적요/가맹점 완전 일치 (고신뢰 = 자동분류)
  KEYWORD // 시드/부분 키워드 포함 매칭 (저신뢰 = 검토 제안)
}

enum FinClassRuleSource {
  USER // 사용자 분류로 학습
  SEED // K-IFRS 시드 키워드
}

enum FinImportStatus {
  DRAFT
  COMMITTED
}

enum FinTxnDirection {
  IN // 수입
  OUT // 지출
}

enum FinClassStatus {
  CLASSIFIED
  REVIEW
  UNCLASSIFIED
}

enum FinStagedResolution {
  NEW
  DUP_SAME // identity 일치 + content 동일 → 건너뜀
  DUP_CHANGED // identity 일치 + content 상이 → 자동 content 반영(분류는 기존 사용자 분류 보존)
  DUP_OVERWRITE // 사용자가 "유지" 명시 선택 → 확정 시 계정과목/분류까지 덮어쓰기
}

enum FinSnapshotSource {
  DERIVED // 거래후잔액에서 파생
  MANUAL // 사용자 입력
}

// 금융 계좌 (은행 계좌 / 카드). 파일 업로드 시 preamble에서 자동 감지 후 사용자 확인.
model FinAccount {
  id                 String         @id @default(cuid())
  spaceId            String
  name               String
  holder             String? // 실제 계좌 예금주명
  kind               FinAccountKind
  institution        String // 은행·카드사명
  accountNumber      String? // 마스킹 가능
  accountType        String? // 입출금/보통예금/법인카드 등
  openingBalance     Decimal?       @db.Decimal(18, 2)
  // 기준(현재) 잔액 — 표시용. 은행 거래 확정 시 마지막 일자 거래후잔액으로 자동 갱신(기준일 이후일 때만).
  // 대시보드 잔액 계산(월별 스냅샷)에는 관여하지 않는다.
  currentBalance     Decimal?       @db.Decimal(18, 2)
  currentBalanceAsOf DateTime?

  space            Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  imports          FinImport[]
  transactions     FinTransaction[]
  stagedRows       FinStagedRow[]
  balanceSnapshots FinBalanceSnapshot[]
  mappingPresets   FinMappingPreset[]
  liabilities      FinLiability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, accountNumber])
  @@index([spaceId])
}

// 부채 (대출 등) — 수기 관리. 대시보드 인라인 Dialog로 잔액 등록/갱신.
model FinLiability {
  id             String   @id @default(cuid())
  spaceId        String
  name           String
  lender         String?
  principal      Decimal  @db.Decimal(18, 2)
  balance        Decimal  @db.Decimal(18, 2)
  rate           String? // "연 4.8%" 등 표시 문자열
  dueDate        String? // "2027-03" 등
  monthlyPayment Decimal? @db.Decimal(18, 2)
  memo           String?
  accountId      String? // 대출 계좌로 지정한 FinAccount (선택)
  // 이 시점까지의 연결 상환 거래는 balance 에 이미 반영됨(워터마크). 이후 상환은 "감지" 대상.
  balanceAsOf    DateTime?

  space        Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account      FinAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  repayments   FinTransaction[] // 이 부채에 귀속된 상환 거래

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([accountId])
}

// 계정과목 트리 (표준 K-IFRS 시드 + 사용자 하위계정). 분류 타깃 = leaf.
model FinCategory {
  id         String          @id @default(cuid())
  spaceId    String
  parentId   String?
  name       String
  code       String? // K-IFRS 코드
  alias      String?
  type       FinCategoryType
  groupLabel String? // 변동비/고정비/마케팅비 등 사용자 그룹
  flowRole   FinFlowRole? // 손익 흐름도 역할 (대분류에만 부여)
  isSystem   Boolean         @default(false)
  isActive   Boolean         @default(true)
  sortOrder  Int             @default(0)

  space    Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent   FinCategory?  @relation("FinCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children FinCategory[] @relation("FinCategoryTree")

  classRules   FinClassRule[]
  transactions FinTransaction[]
  stagedRows   FinStagedRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, parentId, name])
  @@index([spaceId])
  @@index([parentId])
}

// 적요/가맹점 → 계정과목 학습 규칙 (ChannelProductAlias 패턴).
model FinClassRule {
  id          String                @id @default(cuid())
  spaceId     String
  matchKey    String // 정규화된 적요/가맹점 or 키워드
  matchType   FinClassRuleMatchType @default(EXACT)
  categoryId  String
  // 방향별 규칙 구분 — 동일 적요라도 비용(OUT)/수입(IN)을 별개 규칙으로 분류.
  // null = 방향 무관(이체 시드 등). 사용자 EXACT 규칙은 행의 방향(IN/OUT)을 가진다.
  direction   FinTxnDirection?
  learnedFrom FinClassRuleSource    @default(USER)

  space    Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  category FinCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, matchKey, direction])
  @@index([spaceId])
  @@index([categoryId])
}

// 소스별 컬럼 매핑 프리셋 (헤더 → 필드 기억, DelColumnMappingPreset 패턴).
model FinMappingPreset {
  id               String         @id @default(cuid())
  spaceId          String
  name             String
  institution      String
  kind             FinAccountKind
  mapping          Json // Array<{ headerName, field }>
  defaultAccountId String?
  dateFormat       String?

  space          Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  defaultAccount FinAccount? @relation(fields: [defaultAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 업로드 배치 / 스테이징 헤더 (파일 1개 = import 1개).
model FinImport {
  id            String          @id @default(cuid())
  spaceId       String
  accountId     String
  fileName      String
  institution   String
  kind          FinAccountKind
  status        FinImportStatus @default(DRAFT)
  periodFrom    DateTime?
  periodTo      DateTime?
  totalRows     Int             @default(0)
  committedRows Int             @default(0)

  space        Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account      FinAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stagedRows   FinStagedRow[]
  transactions FinTransaction[]

  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([accountId])
}

// 확정 전 검토 행 (commit 시 FinTransaction 으로 승격, dedup 적용).
model FinStagedRow {
  id            String              @id @default(cuid())
  importId      String
  spaceId       String
  accountId     String
  raw           Json
  txnDate       DateTime
  direction     FinTxnDirection
  amount        Decimal             @db.Decimal(18, 2)
  balanceAfter  Decimal?            @db.Decimal(18, 2)
  description   String?
  counterparty  String?
  approvalNo    String?
  cancelFlag    String?
  memo          String? // 사용자 메모 — 저장 처리 시 확정 거래로 이관
  categoryId    String?
  classStatus   FinClassStatus      @default(UNCLASSIFIED)
  matchedRuleId String? // soft ref — 규칙 재학습/삭제 가능
  identityKey   String
  contentHash   String
  resolution    FinStagedResolution @default(NEW)

  import   FinImport    @relation(fields: [importId], references: [id], onDelete: Cascade)
  space    Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account  FinAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category FinCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([importId])
  @@index([spaceId])
}

// 확정 거래 (장부). identityKey unique 로 중복 불가.
model FinTransaction {
  id            String          @id @default(cuid())
  spaceId       String
  accountId     String
  importId      String?
  txnDate       DateTime
  direction     FinTxnDirection
  amount        Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal?        @db.Decimal(18, 2)
  description   String?
  counterparty  String?
  memo          String?
  categoryId    String?
  liabilityId   String? // 상환으로 귀속된 부채 (선택)
  isTransfer    Boolean         @default(false)
  classStatus   FinClassStatus  @default(UNCLASSIFIED)
  matchedRuleId String? // soft ref
  approvalNo    String?
  cancelFlag    String?
  identityKey   String // 안정 키 — BANK: account+date+dir+amount, CARD: 승인번호+이용일+취소구분
  contentHash   String // 가변 필드 해시 — 변경 감지용

  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account   FinAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  import    FinImport?    @relation(fields: [importId], references: [id], onDelete: SetNull)
  category  FinCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  liability FinLiability? @relation(fields: [liabilityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, accountId, identityKey])
  @@index([spaceId, txnDate])
  @@index([spaceId, categoryId])
  @@index([liabilityId])
}

// 계좌 × 월말 잔고 스냅샷 (대시보드 sparkline·재무상태). 거래 없는 달은 직전 스냅샷 이월.
model FinBalanceSnapshot {
  id        String            @id @default(cuid())
  spaceId   String
  accountId String
  yearMonth String // "YYYY-MM"
  balance   Decimal           @db.Decimal(18, 2)
  source    FinSnapshotSource @default(DERIVED)

  space   Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account FinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, accountId, yearMonth])
  @@index([spaceId])
  @@index([accountId])
}

// ════════════════════════════════════════════════════════════════════════════
// 채용 관리 Deck (Hiring) — 공고 제작(hiring-posts) + 지원자 관리(hiring-applicants)
// 두 deck이 이 스키마를 공유한다. PII는 DelOrder 선례(*Enc + *Iv, AES-256-CBC)
// + 매칭용 HMAC-SHA256 해시(*Hash, 키: HIRING_HMAC_KEY) 컬럼을 병행한다.
// 암복호화/해시는 src/lib/hiring/pii.ts 의 write-path 유틸에서만 수행 (Prisma 훅 없음).
// ════════════════════════════════════════════════════════════════════════════

enum HiringPostingStatus {
  DRAFT // 작성 중 (임시저장)
  ACTIVE // 발행됨 — 공개 URL 라이브
  CLOSED // 마감
  ARCHIVED // 보관 (목록 기본 제외)
}

enum HiringJobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCER
  INTERN
}

enum HiringPayFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  PER_TASK
  TBD
}

// 지원 상태머신 1축: 최종 결과
enum HiringApplicationStage {
  HIRING // 진행 중
  ACCEPTED // 합격
  REJECTED // 불합격
}

// 지원 상태머신 2축: 채용 단계
enum HiringProcessStage {
  APPLIED // 서류 접수
  INTERVIEW // 면접
  JOB_OFFER // 처우 협의/최종 제안
}

enum HiringContentSourceType {
  POSTING_DETAIL // 공고 상세 블록
  DETAIL_TEMPLATE // 재사용 템플릿 블록
}

enum HiringNotificationType {
  INTERVIEW
  JOB_OFFER
  ACCEPTED
  REJECTED
}

// 매장/지점 (opening Store — 테넌트 아님, Space 하위 기준정보)
model HiringStore {
  id            String  @id @default(cuid())
  spaceId       String
  name          String
  roadAddress   String? // 도로명 주소
  detailAddress String? // 상세 주소
  zipcode       String?
  isActive      Boolean @default(true)

  space             Space                    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  postingStores     HiringPostingStore[]
  applicationStores HiringApplicationStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// 직무 (opening Position — category는 문자열 스냅샷으로 단순화, 별도 taxonomy 테이블 없음)
model HiringPosition {
  id       String  @id @default(cuid())
  spaceId  String
  name     String
  category String? // 직군 분류 (자유 문자열)
  isActive Boolean @default(true)

  space            Space                   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  postingPositions HiringPostingPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// 채용 공고 (opening Posting)
model HiringPosting {
  id      String              @id @default(cuid())
  spaceId String
  uuid    String              @unique @default(uuid()) // 공개 URL 키 (/p/{uuid})
  title   String
  status  HiringPostingStatus @default(DRAFT)

  // 상세 본문: 섹션 블록 JSON (posting_title/company_intro/positions/stores/manager/content/image …)
  detail Json?

  // ⚠️ 이름 주의: HiringPosting.applicationEntries = 지원서 "폼 스키마" 정의,
  //    HiringApplication.applicationEntries = 지원자가 제출한 "값". (opening 유래 동명이의)
  applicationEntries Json?

  // 담당자 연락처 (PII — 지원자 알림 발신 표기용)
  managerNameEnc  String?
  managerNameIv   String?
  managerPhoneEnc String?
  managerPhoneIv  String?

  closingDate         DateTime? // 마감일 (지나면 CLOSED 처리 — 후속 cron)
  publishedAt         DateTime?
  notificationEnabled Boolean   @default(true)
  authorUserId        String? // 작성자 (Supabase user id — 관계 미연결 스냅샷)

  space        Space                   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  positions    HiringPostingPosition[]
  stores       HiringPostingStore[]
  managers     HiringPostingManager[]
  contents     HiringContent[]
  applications HiringApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([spaceId, createdAt])
}

// 공고 × 직무 상세 (근무조건 스냅샷 — opening PostingPosition)
model HiringPostingPosition {
  id         String  @id @default(cuid())
  spaceId    String
  postingId  String
  positionId String?
  name       String // 직무명 스냅샷

  jobType      HiringJobType?
  payFrequency HiringPayFrequency?
  payAmount    Int? // 급여 (원)
  workDays     Json? // 근무 요일 int[] (0=일 … 6=토)
  workStartAt  String? // "HH:mm"
  workEndAt    String? // "HH:mm"
  headcount    Int? // 모집 인원
  experience   String? // 경력 요건 (자유 문자열)
  education    String? // 학력 요건

  jobDescription          String? // 담당 업무
  requiredQualifications  String?
  preferredQualifications String?

  posting      HiringPosting       @relation(fields: [postingId], references: [id], onDelete: Cascade)
  position     HiringPosition?     @relation(fields: [positionId], references: [id], onDelete: SetNull)
  applications HiringApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id])

  @@index([postingId])
  @@index([spaceId])
}

// 공고 × 매장 조인
model HiringPostingStore {
  id        String @id @default(cuid())
  postingId String
  storeId   String

  posting HiringPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)
  store   HiringStore   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([postingId, storeId])
}

// 공고 × 알림 담당자 (workdeck User id — SpaceMember 전제)
model HiringPostingManager {
  id        String @id @default(cuid())
  postingId String
  userId    String

  posting HiringPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@unique([postingId, userId])
}

// 공고 상세 리치 블록 (Excalidraw 캔버스 — data JSON + export 이미지 storage 키)
model HiringContent {
  id          String                  @id @default(cuid())
  spaceId     String
  sourceType  HiringContentSourceType
  postingId   String? // sourceType=POSTING_DETAIL 일 때
  templateId  String? // sourceType=DETAIL_TEMPLATE 일 때
  contentType String                  @default("excalidraw")
  data        Json? // excalidraw scene JSON
  imagePath   String? // hiring-assets 버킷 내 export PNG 경로
  sortOrder   Int                     @default(0)

  space    Space                 @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  posting  HiringPosting?        @relation(fields: [postingId], references: [id], onDelete: Cascade)
  template HiringDetailTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postingId])
  @@index([templateId])
  @@index([spaceId])
}

// 재사용 상세 템플릿
model HiringDetailTemplate {
  id        String  @id @default(cuid())
  spaceId   String
  name      String
  data      Json? // 섹션 블록 JSON
  imagePath String? // 대표 이미지 storage 경로

  space    Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  contents HiringContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// 지원서 (opening Application — 지원자는 비인증 익명 레코드)
model HiringApplication {
  id                String  @id @default(cuid())
  spaceId           String
  postingId         String
  postingPositionId String?
  uuid              String  @unique @default(uuid()) // 내부/공개 참조 키

  // 제출값 JSON — 표준 PII 항목(name/phone/email/address)은 값 제거 후 아래 enc 컬럼으로 이동,
  // 커스텀 항목만 값 유지. (src/lib/hiring/pii.ts 참조)
  applicationEntries Json?

  // PII (AES enc + iv, 매칭 필요한 것만 HMAC hash)
  nameEnc             String?
  nameIv              String?
  nameHash            String?
  maskedName          String? // 목록 표시용 마스킹 이름 (홍*동)
  phoneEnc            String?
  phoneIv             String?
  phoneHash           String? // 중복판정·블랙리스트 매칭 키
  phoneLastDigitsHash String? // 뒷 4자리 검색
  emailEnc            String?
  emailIv             String?
  emailHash           String?
  addressEnc          String?
  addressIv           String?

  stage       HiringApplicationStage @default(HIRING)
  hiringStage HiringProcessStage     @default(APPLIED)

  referrer           String? // 유입 잡보드 (jobkorea/saramin/albamon/wanted …)
  directRegistration Boolean @default(false) // 고용주 직접 등록
  duplicated         Boolean @default(false) // phoneHash 중복 감지
  memo               String?

  privacyAgreedAt DateTime?
  canceledAt      DateTime?
  deletedAt       DateTime? // 소프트 삭제

  space           Space                           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  posting         HiringPosting                   @relation(fields: [postingId], references: [id], onDelete: Cascade)
  postingPosition HiringPostingPosition?          @relation(fields: [postingPositionId], references: [id], onDelete: SetNull)
  stores          HiringApplicationStore[]
  files           HiringApplicationFile[]
  comments        HiringComment[]
  notifications   HiringApplicationNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, stage])
  @@index([spaceId, createdAt])
  @@index([postingId])
  @@index([spaceId, phoneHash])
}

// 지원 × 매장 조인 (지원자가 선택한 근무 희망 매장)
model HiringApplicationStore {
  id            String @id @default(cuid())
  applicationId String
  storeId       String

  application HiringApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  store       HiringStore       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([applicationId, storeId])
}

// 지원자 첨부 파일 (이력서 등 — hiring-files 비공개 버킷, 서명 URL 접근만)
model HiringApplicationFile {
  id            String @id @default(cuid())
  spaceId       String
  applicationId String
  fileName      String // 원본 파일명
  filePath      String // 비공개 버킷 내 경로
  mimeType      String
  sizeBytes     Int

  application HiringApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([spaceId])
}

// 지원서 내부 메모 (고용주 팀 코멘트)
model HiringComment {
  id            String    @id @default(cuid())
  spaceId       String
  applicationId String
  userId        String // 작성자 (Supabase user id)
  content       String
  editedAt      DateTime?
  deletedAt     DateTime?

  application HiringApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
}

// 지원자 상태 알림 (uuid + tokenHash 로 30일 공개 열람)
model HiringApplicationNotification {
  id            String                 @id @default(cuid())
  spaceId       String
  applicationId String
  senderUserId  String? // 발송한 담당자
  notiType      HiringNotificationType
  detailMessage String?
  uuid          String                 @unique
  tokenHash     String // 원문 토큰은 저장하지 않음 — HMAC 해시만 (상수시간 비교)
  tokenExpireAt DateTime
  sentAt        DateTime?

  application HiringApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([applicationId])
}

// 블랙리스트 (phoneHash 매칭)
model HiringBlacklist {
  id        String  @id @default(cuid())
  spaceId   String
  phoneEnc  String
  phoneIv   String
  phoneHash String
  reason    String?
  isActive  Boolean @default(true)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, phoneHash])
}

// 지원자 알림 메시지 템플릿
model HiringMessageTemplate {
  id         String    @id @default(cuid())
  spaceId    String
  title      String
  content    String
  lastUsedAt DateTime?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}


// ─── 블로그 운영 Deck (Blog Ops) ──────────────────────────────────────────────

enum BoCrawlStatus {
  NONE
  PENDING
  DONE
  FAILED
}

enum BoMaterialStatus {
  PROPOSED
  APPROVED
  REJECTED
  ARCHIVED
}

// 블로그 소재 발굴 대상 제품. 홈페이지 크롤 결과·AI 소구점 분석의 기준점.
model BoProduct {
  id             String        @id @default(cuid())
  spaceId        String
  name           String
  category       String? // B2B / B2C
  oneLinerPitch  String?
  homepageUrl    String?
  crawledText    String?
  crawledAt      DateTime?
  crawlStatus    BoCrawlStatus @default(NONE)
  targetCustomer String?
  features       Json          @default("[]") // [{ name: string, description: string }]
  ctaUrl         String?
  customFields   Json          @default("[]") // [{ key: string, value: string }]
  isActive       Boolean       @default(true)

  space     Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  ideations BoIdeation[]
  materials BoMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// AI 소구점 발굴 실행 단위. 한 번의 생성 호출 결과를 appealPoints Json으로 보관.
model BoIdeation {
  id              String  @id @default(cuid())
  spaceId         String
  userId          String?
  productId       String
  userPromptInput String?
  appealPoints    Json    @default("[]") // [{ point, evidence, targetPain, priority }]
  providerName    String?
  providerModel   String?
  latencyMs       Int?
  promptTraceHash String?

  space     Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  product   BoProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)
  materials BoMaterial[]

  createdAt DateTime @default(now())

  @@index([spaceId, createdAt])
  @@index([productId])
}

// 블로그 포스팅 소재. 소구점 하나를 특정 앵글로 풀어낸 글 골격.
model BoMaterial {
  id               String           @id @default(cuid())
  spaceId          String
  productId        String
  ideationId       String?
  title            String
  appealPoint      String
  angle            String
  outline          Json             @default("[]") // [{ section: string, description: string }]
  targetKeyword    String?
  status           BoMaterialStatus @default(PROPOSED)
  approvedByUserId String?
  approvedAt       DateTime?

  space    Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  product  BoProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  ideation BoIdeation? @relation(fields: [ideationId], references: [id], onDelete: SetNull)
  posts    BoPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([productId])
}

enum BoPostStatus {
  GENERATING
  DRAFT
  IN_REVIEW
  PUBLISH_APPROVED
  PUBLISHED
  FAILED
  ARCHIVED
}

enum BoPlatform {
  NAVER_BLOG
  TISTORY
  OWN_HOMEPAGE
}

enum BoPublisherMode {
  MANUAL
  BROWSER
}

enum BoVariantStatus {
  GENERATING
  READY
  EDITED
  FAILED
}

enum BoDeploymentStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
  EXPORTED
  DELETING
  DELETED
}

// 블로그 포스트. 소재(BoMaterial)를 기반으로 AI가 생성한 실제 글 본문.
model BoPost {
  id                      String        @id @default(cuid())
  spaceId                 String
  userId                  String?
  materialId              String
  title                   String
  doc                     Json          // TipTap master doc
  bodyMarkdown            String?
  status                  BoPostStatus  @default(GENERATING)
  targetKeyword           String?
  relatedKeywords         Json          @default("[]")
  ctaUrl                  String?
  publishApprovedByUserId String?
  publishApprovedAt       DateTime?
  generationTraceHash     String?
  errorMessage            String?

  space       Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  material    BoMaterial      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  versions    BoPostVersion[]
  variants    BoPostVariant[]
  deployments BoDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([materialId])
}

// 포스트 버전 이력. 수동 저장·AI 재생성 시마다 스냅샷 누적.
model BoPostVersion {
  id              String  @id @default(cuid())
  postId          String
  spaceId         String
  versionNumber   Int
  title           String
  doc             Json
  note            String?
  createdByUserId String?

  post  BoPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  space Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, versionNumber])
  @@index([spaceId, createdAt])
}

// 블로그 배포 채널. 플랫폼(네이버·티스토리·자사 홈페이지)별 설정을 보관한다.
model BoChannel {
  id            String          @id @default(cuid())
  spaceId       String
  platform      BoPlatform
  name          String
  formatProfile Json            @default("{}")
  publisherMode BoPublisherMode @default(MANUAL)
  config        Json?
  isActive      Boolean         @default(true)

  space       Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  variants    BoPostVariant[]
  deployments BoDeployment[]
  credentials BoChannelCredential[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, platform, name])
  @@index([spaceId])
}

// 포스트 × 채널별 변형. 채널 포맷에 맞춰 변환된 제목·본문·내보내기 결과를 보관한다.
model BoPostVariant {
  id               String          @id @default(cuid())
  spaceId          String
  postId           String
  channelId        String
  title            String
  doc              Json
  exportedMarkdown String?
  exportedHtml     String?
  status           BoVariantStatus @default(GENERATING)
  errorMessage     String?

  space       Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  post        BoPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  channel     BoChannel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  deployments BoDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, channelId])
  @@index([spaceId])
}

// 포스트 배포 이력. 변형 1건을 채널에 게시한 실행 단위.
model BoDeployment {
  id           String             @id @default(cuid())
  spaceId      String
  postId       String
  variantId    String
  channelId    String
  status       BoDeploymentStatus @default(PENDING)
  platformUrl  String?
  errorCode    String?
  errorMessage String?
  publishedAt  DateTime?
  scheduledAt  DateTime? // 예약 발행 시각 (null = 즉시 발행)
  deletedAt    DateTime? // 플랫폼에서 글 삭제 완료 시각

  space   Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  post    BoPost        @relation(fields: [postId], references: [id], onDelete: Cascade)
  variant BoPostVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  channel BoChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, status])
  @@index([postId])
}

// ─── Blog Ops Deck (자격증명 · 작업 큐) ──────────────────────────────────────

enum BoJobKind {
  CRAWL_HOMEPAGE
  GENERATE_DRAFT
  GENERATE_VARIANT
  PUBLISH
  DELETE_POST
}

enum BoJobStatus {
  PENDING
  CLAIMED
  COMPLETED
  FAILED
}

enum BoCredentialKind {
  COOKIE
  OAUTH
  API_KEY
}

// DB-backed 작업 큐. 워커가 주기 polling 해서 claim → 처리 → complete.
model BoJob {
  id           String      @id @default(cuid())
  spaceId      String
  kind         BoJobKind
  status       BoJobStatus @default(PENDING)
  targetId     String? // variantId · deploymentId 등 대상 엔터티 id
  payload      Json? // kind 별 페이로드
  scheduledAt  DateTime    @default(now())
  claimedAt    DateTime?
  claimedBy    String? // 워커 instance id
  completedAt  DateTime?
  attempts     Int         @default(0)
  errorMessage String?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([spaceId, status])
  @@index([kind, status])
}

// 채널별 자격증명. AES-256-CBC 암호화 페이로드 보관 (sc/credentials.ts 와 동일 구조).
model BoChannelCredential {
  id               String           @id @default(cuid())
  spaceId          String
  channelId        String
  kind             BoCredentialKind
  encryptedPayload String // hex 인코딩 AES-256-CBC
  iv               String // hex iv
  expiresAt        DateTime?
  lastVerifiedAt   DateTime?
  lastError        String?

  space   Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel BoChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, kind])
  @@index([channelId])
  @@index([spaceId])
}
