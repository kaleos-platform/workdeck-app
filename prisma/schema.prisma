// 쿠팡 광고 리포트 매니저 데이터 모델

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 데이터 수집 열거형 ──────────────────────────────────────────────────────

enum CollectionStatus {
  PENDING
  RUNNING
  DOWNLOADING
  PARSING
  COMPLETED
  FAILED
}

// ─── 실행 태스크 열거형 ──────────────────────────────────────────────────────

enum ActionType {
  REMOVE_KEYWORD
  ADJUST_BID
  PAUSE_CAMPAIGN
  RESUME_CAMPAIGN
  ADJUST_BUDGET
}

enum ExecutionStatus {
  PENDING_APPROVAL
  APPROVED
  EXECUTING
  COMPLETED
  FAILED
  ROLLED_BACK
}

// ─── AI 분석 열거형 ──────────────────────────────────────────────────────────

enum AnalysisType {
  DAILY_REVIEW
  KEYWORD_AUDIT
  BUDGET_OPTIMIZATION
  CAMPAIGN_SCORING
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Workdeck OS 열거형 ───────────────────────────────────────────────────────

enum SpaceType {
  PERSONAL
  ORGANIZATION
}

enum SpaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── 셀러 허브 열거형 ─────────────────────────────────────────────────────────

enum ChannelKind {
  ONLINE_MARKETPLACE
  ONLINE_MALL
  OFFLINE
  INTERNAL_TRANSFER
  OTHER
}

// 판매채널 상품 상태 — 시스템 재고 0일 때는 effective status가 SOLD_OUT으로 표시됨 (DB에는 저장 X).
enum ProductListingStatus {
  ACTIVE
  SUSPENDED
}

// ─── 사용자 모델 (Supabase Auth와 연동) ──────────────────────────────────────

model User {
  id        String  @id // Supabase Auth UUID를 그대로 사용 (no default)
  email     String  @unique
  name      String?
  avatarUrl String?

  // 소유한 워크스페이스 (기존 — 점진 전환 기간 동안 유지)
  workspace Workspace?

  // Workdeck OS: 공간 멤버십
  spaceMemberships SpaceMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 워크스페이스 (쿠팡 사업자 단위)
model Workspace {
  id      String @id @default(cuid())
  name    String // 쿠팡 사업자명

  // 소유 사용자
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // 연관 데이터
  reportUploads    ReportUpload[]
  adRecords        AdRecord[]
  dailyMemos       DailyMemo[]
  campaignMetas    CampaignMeta[]
  keywordStatuses  KeywordStatus[]
  campaignTargets  CampaignTarget[]
  productStatuses  ProductStatus[]

  // AI 분석 리포트
  analysisReports  AnalysisReport[]

  // 실행 태스크
  executionTasks   ExecutionTask[]
  safetyLimits     SafetyLimits?

  // 비즈니스 에이전트
  businessAgent    BusinessAgent?

  // 학습형 분석 규칙
  analysisRules    AnalysisRule[]

  // 분석 자동 스케줄
  analysisSchedule AnalysisSchedule?

  // 데이터 수집 관련
  coupangCredential   CoupangCredential?
  collectionSchedule  CollectionSchedule?
  collectionRuns      CollectionRun[]

  // 재고 관리
  inventoryUploads          InventoryUpload[]
  inventoryRecords          InventoryRecord[]
  inventoryExcludedProducts InventoryExcludedProduct[]
  inventoryAnalyses         InventoryAnalysis[]

  createdAt DateTime @default(now())
}

// 업로드 이력
model ReportUpload {
  id          String   @id @default(cuid())
  fileName    String
  uploadedAt  DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime

  // 처리 결과 통계
  totalRows     Int?
  insertedRows  Int?
  duplicateRows Int?
  skippedRows   Int?

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 이 업로드에서 파싱된 광고 데이터
  adRecords AdRecord[]

  @@index([workspaceId])
}

// 광고 데이터 행 (Excel 한 행 = 하나의 AdRecord)
model AdRecord {
  id           String   @id @default(cuid())
  date         DateTime
  adType       String   // 광고유형 (예: 키워드 광고, 상품 광고)
  campaignId   String
  campaignName String
  adGroup      String?  // 광고그룹
  placement    String?  // 광고 노출 지면
  productName  String?  // 광고집행 상품명
  optionId     String?  // 광고집행 옵션ID
  keyword      String?  // 키워드 (없을 수 있음)

  // 노출·클릭
  impressions Int
  clicks      Int
  adCost      Decimal  @db.Decimal(18, 2) // 광고비
  ctr         Decimal  @db.Decimal(10, 4) // 클릭률

  // 1일 전환 지표
  orders1d    Int
  revenue1d   Decimal  @db.Decimal(18, 2) // 직접 전환매출액 (1일)
  roas1d      Decimal  @db.Decimal(10, 4) // 직접 광고수익률 (1일)

  // NCA 공통 필드
  material       String?  // 소재 (NCA: 소재 컬럼)

  // NCA 동영상 지표 (없으면 null)
  videoViews3s   Int?     // 동영상 3초 조회
  avgPlayTime    Decimal? @db.Decimal(10, 2)  // 평균 재생 시간
  videoViews25p  Int?     // 25% 재생수
  videoViews50p  Int?     // 50% 재생수
  videoViews75p  Int?     // 75% 재생수
  videoViews100p Int?     // 100% 재생수
  costPerView3s  Decimal? @db.Decimal(18, 2)  // 동영상 3초 조회당 비용
  engagements    Int?     // 참여수
  engagementRate Decimal? @db.Decimal(10, 4)  // 참여율

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 소속 업로드 이력
  reportId String
  report   ReportUpload @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, campaignId, adType, keyword, adGroup, optionId])
  @@index([workspaceId, campaignId])
  @@index([workspaceId, date])
}

// 캠페인 메타 (표시명 커스터마이징)
model CampaignMeta {
  id           String    @id @default(cuid())
  workspaceId  String
  campaignId   String
  displayName  String
  isCustomName Boolean   @default(false)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, campaignId])
  @@index([workspaceId])
}

// 키워드 제거 상태 관리
model KeywordStatus {
  id          String    @id @default(cuid())
  workspaceId String
  campaignId  String
  keyword     String
  removedAt   DateTime?
  removedMemo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, keyword])
  @@index([workspaceId, campaignId])
}

// 캠페인 일 예산 / 목표 ROAS 설정 이력 (effectiveDate 기반)
model CampaignTarget {
  id            String   @id @default(cuid())
  workspaceId   String
  campaignId    String
  effectiveDate DateTime @db.Date // 이 값이 적용되기 시작하는 날짜
  dailyBudget   Int? // 일 예산 (원), null = 미설정
  targetRoas    Float? // 목표 ROAS (%), null = 미설정
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, effectiveDate])
  @@index([workspaceId, campaignId, effectiveDate])
}

// 상품 제거 상태 관리
model ProductStatus {
  id          String    @id @default(cuid())
  workspaceId String
  campaignId  String
  productName String
  optionId    String    @default("")
  removedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, campaignId, productName, optionId])
  @@index([workspaceId, campaignId])
}

// 일자별 메모 (캠페인별 광고 작업 이력)
model DailyMemo {
  id         String   @id @default(cuid())
  campaignId String
  date       DateTime
  content    String

  // 소속 워크스페이스
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 워크스페이스 + 캠페인 + 날짜 조합은 유일
  @@unique([workspaceId, campaignId, date])
  @@index([workspaceId, campaignId])
}

// ─── Workdeck OS 모델 ─────────────────────────────────────────────────────────

// 공간 (개인 or 조직 테넌트)
model Space {
  id   String    @id @default(cuid())
  name String
  type SpaceType @default(PERSONAL)

  members       SpaceMember[]
  deckInstances DeckInstance[]

  // 통합 재고 관리 (Inv)
  invProducts         InvProduct[]
  invLocations        InvStorageLocation[]
  invMovements        InvMovement[]
  invStockLevels      InvStockLevel[]
  invImportHistories  InvImportHistory[]
  invReconciliations  InvReconciliation[]
  invLocationMappings InvLocationProductMap[]
  invSettings         InvSettings?
  invProductGroups    InvProductGroup[]

  // 통합 배송 관리 (Del)
  delShippingMethods       DelShippingMethod[]
  delBatches               DelBatch[]
  delOrders                DelOrder[]
  delIntegrationHistories  DelIntegrationHistory[]
  delColumnMappingPresets  DelColumnMappingPreset[]
  channelProductAliases    ChannelProductAlias[]
  delShippingMethodLabels  DelShippingMethodLabel[]

  // 셀러 허브 공용 (Seller Hub)
  channels               Channel[]
  channelGroups          ChannelGroup[]
  brands                 Brand[]
  productPricingSettings ProductPricingSettings?
  optionCodeAliases      SpaceOptionCodeAlias[]
  productListings        ProductListing[]
  productChannelGroupMeta ProductChannelGroupMeta[]
  productionRuns         ProductionRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 공간 멤버십 + 역할
model SpaceMember {
  id      String          @id @default(cuid())
  spaceId String
  userId  String
  role    SpaceMemberRole @default(MEMBER)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([spaceId, userId])
  @@index([userId])
}

// 카드 앱 카탈로그 (전역 정의)
model DeckApp {
  id          String  @id // "coupang-ads", "osmu", "commerce-ops"
  name        String
  description String?
  isActive    Boolean @default(true)

  instances DeckInstance[]
}

// Space에서 활성화된 카드 인스턴스
model DeckInstance {
  id        String  @id @default(cuid())
  spaceId   String
  deckAppId String
  isActive  Boolean @default(true)

  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  deckApp DeckApp @relation(fields: [deckAppId], references: [id])

  createdAt DateTime @default(now())

  @@unique([spaceId, deckAppId])
  @@index([spaceId])
}

// ─── 데이터 수집 모델 ────────────────────────────────────────────────────────

// 쿠팡 로그인 자격증명 (워크스페이스당 1개)
model CoupangCredential {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  loginId       String
  loginPassword String
  encryptionIv  String
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  lastError     String?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 자동 수집 스케줄 (워크스페이스당 1개)
model CollectionSchedule {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  enabled        Boolean   @default(true)
  cronExpression String    @default("30 12 * * *")
  timezone       String    @default("Asia/Seoul")
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 수집 실행 이력
model CollectionRun {
  id             String           @id @default(cuid())
  workspaceId    String
  status         CollectionStatus @default(PENDING)
  triggeredBy    String
  startedAt      DateTime?
  completedAt    DateTime?
  error          String?
  uploadId       String?
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

// ─── AI 분석 리포트 ─────────────────────────────────────────────────────────

model AnalysisReport {
  id          String         @id @default(cuid())
  workspaceId String
  periodStart DateTime
  periodEnd   DateTime
  reportType  AnalysisType
  summary     String         @db.Text
  suggestions Json
  metadata    Json?
  status      AnalysisStatus @default(PENDING)
  triggeredBy String         @default("manual")
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

// ─── 반자동 실행 인프라 ───────────────────────────────────────────────────────

// 실행 태스크 (AI 제안 → 승인 → 실행 흐름)
model ExecutionTask {
  id               String          @id @default(cuid())
  workspaceId      String
  analysisReportId String?
  actionType       ActionType
  campaignId       String
  target           String
  params           Json
  status           ExecutionStatus @default(PENDING_APPROVAL)
  beforeState      Json?
  afterState       Json?
  approvedAt       DateTime?
  approvedBy       String?
  executedAt       DateTime?
  error            String?
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([workspaceId, status])
}

// 안전 제한 설정 (워크스페이스당 1개)
model SafetyLimits {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  maxBidChangePct     Int       @default(30)
  maxKeywordsPerBatch Int       @default(20)
  maxBudgetChangePct  Int       @default(50)
  requireApproval     Boolean   @default(true)
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// 학습형 분석 규칙 (사용자/모델/시스템이 추가한 분석 기준)
model AnalysisRule {
  id           String    @id @default(cuid())
  workspaceId  String
  rule         String    @db.Text
  source       String    // "user" | "model" | "system"
  isActive     Boolean   @default(true)
  appliedCount Int       @default(0)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceId, isActive])
}

// 분석 자동 스케줄 (워크스페이스당 1개)
model AnalysisSchedule {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  enabled                Boolean   @default(true)
  intervalDays           Int       @default(7)
  analysisHour           Int?
  triggerAfterCollection Boolean   @default(false)
  slackNotify            Boolean   @default(true)
  lastAnalyzedAt         DateTime?
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// 비즈니스 에이전트 (의식주의 Slack 에이전트)
model BusinessAgent {
  id             String     @id @default(cuid())
  workspaceId    String     @unique
  slackChannelId String?
  slackBotToken  String?
  isActive       Boolean    @default(true)
  lastActiveAt   DateTime?
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs           AgentLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // command, notification, error
  command   String?  // 사용자 입력 명령 (예: "상태", "분석")
  response  String?  // 에이전트 응답 요약
  channel   String?  // Slack 채널 ID
  agent     BusinessAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId, createdAt(sort: Desc)])
}

// ─── 재고 관리 ────────────────────────────────────────────────

// 재고 엑셀 업로드 이력
model InventoryUpload {
  id           String   @id @default(cuid())
  fileName     String
  fileType     String   // INVENTORY_HEALTH | VENDOR_ITEM_METRICS
  uploadedAt   DateTime @default(now())
  snapshotDate DateTime // 데이터 기준일
  totalRows    Int?
  insertedRows Int?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  inventoryRecords InventoryRecord[]

  @@index([workspaceId])
}

// 재고 / 상품 성과 레코드
model InventoryRecord {
  id           String   @id @default(cuid())
  workspaceId  String
  snapshotDate DateTime
  fileType     String   // INVENTORY_HEALTH | VENDOR_ITEM_METRICS

  // 상품 식별
  productId   String  // 등록상품ID
  optionId    String  // 옵션ID
  skuId       String? // SKU ID
  productName String
  optionName  String?
  category    String?

  // 재고 (inventory_health)
  availableStock     Int?    // 판매가능재고
  inboundStock       Int?    // 입고예정재고
  productGrade       String? // 상품등급 (NEW 등)
  restockQty         Int?    // 추가입고 추천수량
  restockDate        String? // 추가입고날짜
  estimatedDepletion String? // 재고예상 소진일
  storageFee         Int?    // 이번달 누적보관료
  isItemWinner       Boolean? // 아이템위너 여부
  returns30d         Int?    // 고객반품 30일

  // 매출/판매
  revenue7d   Decimal? @db.Decimal(18, 2)
  revenue30d  Decimal? @db.Decimal(18, 2)
  salesQty7d  Int?
  salesQty30d Int?

  // vendor_item_metrics 전용
  visitors       Int?
  views          Int?
  cartAdds       Int?
  conversionRate Decimal? @db.Decimal(10, 4) // 구매전환율 %
  itemWinnerRate Decimal? @db.Decimal(10, 4) // 아이템위너 비율 %
  totalRevenue   Decimal? @db.Decimal(18, 2)
  totalSales     Int?
  totalCancelAmt Decimal? @db.Decimal(18, 2)
  totalCancelled Int?

  // 보관기간별 재고
  stock1to30d    Int?
  stock31to45d   Int?
  stock46to60d   Int?
  stock61to120d  Int?
  stock121to180d Int?
  stock181plusD   Int?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadId  String
  upload    InventoryUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, snapshotDate, productId, optionId, fileType])
  @@index([workspaceId, snapshotDate])
  @@index([workspaceId, productName])
}

// 재고 관리 제외 옵션
model InventoryExcludedProduct {
  id          String   @id @default(cuid())
  workspaceId String
  productId   String
  optionId    String
  excludedAt  DateTime @default(now())
  reason      String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, optionId])
  @@index([workspaceId])
}

// 재고 분석 결과
model InventoryAnalysis {
  id           String   @id @default(cuid())
  workspaceId  String
  snapshotDate DateTime
  analysedAt   DateTime @default(now())
  triggeredBy  String   @default("manual")

  results          Json
  shortageCount    Int @default(0)
  returnRateCount  Int @default(0)
  storageFeeCount  Int @default(0)
  winnerIssueCount Int @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, analysedAt(sort: Desc)])
}

// ─── 통합 재고 관리 (Inv) ─────────────────────────────────────────────────────

enum InvMovementType {
  INBOUND
  OUTBOUND
  RETURN
  TRANSFER
  ADJUSTMENT
}

enum InvReconciliationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// 상품 그룹 (카테고리)
model InvProductGroup {
  id      String @id @default(cuid())
  spaceId String
  name    String

  space    Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  products InvProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 상품 (옵션 단위로 관리)
model InvProduct {
  id      String  @id @default(cuid())
  spaceId String
  name    String  // 공식 상품명 — 판매채널 노출명 (필수)
  code    String? // 상품 코드 (space 내 unique, null 허용)
  groupId String  // 카테고리 필수 (non-null)

  // 셀러 허브 확장 필드 (모두 nullable)
  brandId            String?
  internalName       String?   // 관리 상품명 — 내부 식별용. 비어있으면 표시 시 name으로 fallback
  nameEn             String?
  manufacturer       String?
  manufactureCountry String?
  manufactureDate    DateTime?
  features           Json?
  certifications     Json?
  msrp               Decimal?  @db.Decimal(18, 2)
  description        String?
  optionAttributes   Json?     // 예: [{name:"사이즈",values:["S","M","L"]}]

  space            Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  group            InvProductGroup           @relation(fields: [groupId], references: [id], onDelete: Restrict)
  brand            Brand?                    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  options          InvProductOption[]
  reorderConfig    InvReorderConfig?
  channelGroupMeta ProductChannelGroupMeta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, code])
  @@index([spaceId])
  @@index([groupId])
  @@index([brandId])
}

// 상품 옵션
model InvProductOption {
  id        String @id @default(cuid())
  productId String
  name      String
  sku       String?

  // 셀러 허브 확장 필드 (모두 nullable)
  costPrice       Decimal? @db.Decimal(18, 2)
  retailPrice     Decimal? @db.Decimal(18, 2)
  sizeLabel       String?
  setSizeLabel    String?
  attributeValues Json?    // 예: {"사이즈":"S","색상":"파랑"}

  product           InvProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements         InvMovement[]
  stockLevels       InvStockLevel[]
  locationMappings  InvLocationProductMap[]
  productionRunItems ProductionRunItem[]
  delOrderItems     DelOrderItem[]
  channelAliases    ChannelProductAlias[]
  aliasFulfillments ChannelProductAliasFulfillment[]
  shippingLabels    DelShippingMethodLabel[]
  listingItems      ProductListingItem[]
  fulfillments      DelOrderItemFulfillment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// 보관 장소
model InvStorageLocation {
  id       String  @id @default(cuid())
  spaceId  String
  name     String
  isActive Boolean @default(true)

  space           Space                  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  stockLevels     InvStockLevel[]
  movements       InvMovement[]          @relation("MovementLocation")
  incomingTransfers InvMovement[]         @relation("MovementToLocation")
  locationMappings InvLocationProductMap[]
  reconciliations InvReconciliation[]
  settingsDefault InvSettings[]          @relation("DefaultLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// 재고 이동 원장 (불변 레코드)
model InvMovement {
  id         String @id @default(cuid())
  spaceId    String
  optionId   String
  locationId String

  toLocationId    String? // TRANSFER 전용
  channelId       String? // OUTBOUND 전용 (셀러 허브 공용 Channel FK)
  type            InvMovementType
  quantity        Int
  movementDate    DateTime
  orderDate       DateTime? // OUTBOUND 전용
  reason          String?   // ADJUSTMENT 시 필수 (앱 레벨 검증)
  referenceId     String?   // 연관 이동 또는 조정 ID
  importHistoryId String?

  space         Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  option        InvProductOption    @relation(fields: [optionId], references: [id], onDelete: Cascade)
  location      InvStorageLocation  @relation("MovementLocation", fields: [locationId], references: [id], onDelete: Cascade)
  toLocation    InvStorageLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  channel       Channel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  importHistory InvImportHistory?   @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([optionId])
  @@index([locationId])
  @@index([spaceId, movementDate])
}

// 현재 재고 수준 (옵션 × 장소)
model InvStockLevel {
  id         String @id @default(cuid())
  spaceId    String
  optionId   String
  locationId String
  quantity   Int    @default(0) // 음수 가능

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  option   InvProductOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([optionId, locationId])
  @@index([spaceId])
}

// 상품별 발주 예측 설정 — 한 상품의 모든 옵션이 동일한 리드타임/안전재고를 공유
model InvReorderConfig {
  id                 String @id @default(cuid())
  productId          String @unique
  leadTimeDays       Int    @default(7)
  safetyStockQty     Int    @default(0)
  analysisWindowDays Int    @default(90)

  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// 대량 가져오기 이력
model InvImportHistory {
  id          String @id @default(cuid())
  spaceId     String
  fileName    String
  fileType    String // "EXCEL" | "CSV"
  totalRows   Int
  successRows Int
  errorRows   Int
  errors      Json?  // 행 단위 에러 상세

  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  movements InvMovement[]

  importedAt DateTime @default(now())

  @@index([spaceId])
}

// 파일 기반 재고 대사 이력
model InvReconciliation {
  id           String                   @id @default(cuid())
  spaceId      String
  locationId   String
  fileName     String
  snapshotDate DateTime
  status       InvReconciliationStatus  @default(PENDING)
  matchResults Json                     // 매칭/차이 상세
  totalItems   Int
  matchedItems Int
  adjustedItems Int                     @default(0)

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([spaceId])
}

// 보관 장소별 외부 상품 코드 매핑
model InvLocationProductMap {
  id         String @id @default(cuid())
  spaceId    String
  locationId String
  optionId   String

  externalCode       String  // 보관 장소의 상품 코드/ID
  externalName       String? // 보관 장소의 상품명 (참조용)
  externalOptionName String? // 보관 장소의 옵션명 (참조용)

  space    Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  location InvStorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  option   InvProductOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([locationId, externalCode])
  @@index([spaceId])
  @@index([optionId])
}

// 공간별 재고 덱 설정
model InvSettings {
  id                String  @id @default(cuid())
  spaceId           String  @unique
  defaultLocationId String?
  slackWebhookUrl   String?
  preferences       Json    @default("{}")

  space           Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  defaultLocation InvStorageLocation? @relation("DefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)

  @@index([spaceId])
}

// ─── 통합 배송 관리 (Del) ─────────────────────────────────────────────────────

enum DelBatchStatus {
  DRAFT
  COMPLETED
}

// 배송 방식 (택배사 + 파일 포맷)
model DelShippingMethod {
  id               String  @id @default(cuid())
  spaceId          String
  name             String
  isActive         Boolean @default(true)
  formatConfig     Json    // DelFormatColumn[] — 배송 파일 컬럼 매핑
  labelColumns     Json    @default("[]")  // string[] — 활성화된 DelFieldMapping 키 (max 3). 배송 파일 생성 시 이 컬럼만 옵션별 값으로 덮어씀.
  defaultSplitMode String  @default("order")  // 'order' | 'option' — 배송 파일 생성 시 기본 분할 모드

  space  Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  orders DelOrder[]
  productLabels DelShippingMethodLabel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 배송 방식 × 옵션별 필드 오버라이드 (배송 파일 생성 시 적용)
model DelShippingMethodLabel {
  id               String @id @default(cuid())
  spaceId          String
  shippingMethodId String
  optionId         String
  overrides        Json   // { [field: DelFieldMapping]: string }

  space          Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  shippingMethod DelShippingMethod @relation(fields: [shippingMethodId], references: [id], onDelete: Cascade)
  option         InvProductOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shippingMethodId, optionId])
  @@index([spaceId])
  @@index([optionId])
}

// 배송 배치 (한 번의 배송 등록 작업 단위)
model DelBatch {
  id          String         @id @default(cuid())
  spaceId     String
  status      DelBatchStatus @default(DRAFT)
  label       String?

  space  Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  orders DelOrder[]

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([spaceId])
  @@index([spaceId, status])
}

// 개별 주문 (배송 등록 행 1개)
model DelOrder {
  id               String @id @default(cuid())
  spaceId          String
  batchId          String
  shippingMethodId String?
  channelId        String? // 셀러 허브 공용 Channel FK

  // PII 암호화 필드
  recipientNameEnc String
  recipientNameIv  String
  phoneEnc         String
  phoneIv          String
  addressEnc       String
  addressIv        String
  postalCode       String?  // 우편번호 (비PII)
  deliveryMessage  String?
  memo             String?  // 사용자 메모

  // 주문 메타
  orderDate     DateTime
  orderNumber   String?
  paymentAmount Decimal? @db.Decimal(18, 2)

  space          Space              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  batch          DelBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  shippingMethod DelShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  channel        Channel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items          DelOrderItem[]

  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([batchId])
  @@index([spaceId, orderDate])
}

// 주문 상품 (max 10, 앱 레벨 검증)
model DelOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  name      String  // 원본 텍스트 — 미매칭 fallback 및 감사용
  quantity  Int
  optionId  String? // 단일 옵션 매칭 — InvProductOption.id (listingId와 상호 배타)
  listingId String? // 판매채널 상품(ProductListing) 매칭 — fulfillments로 실제 출고 옵션·수량 팬아웃

  order        DelOrder                  @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  option       InvProductOption?         @relation(fields: [optionId],  references: [id], onDelete: SetNull)
  listing      ProductListing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  fulfillments DelOrderItemFulfillment[]

  @@index([orderId])
  @@index([optionId])
  @@index([listingId])
}

// 채널별 상품 별칭 사전 — 원본 상품명을 판매채널 상품(listing) 또는 단일 옵션에 매핑.
// optionId 또는 listingId 중 하나가 필수 (CHECK 제약으로 보장).
// 매칭 우선순위: listingId 있으면 listing, 아니면 optionId.
model ChannelProductAlias {
  id        String  @id @default(cuid())
  spaceId   String
  channelId String
  aliasName String  // 정규화된 원본 상품명 (normalizeAlias 출력)
  optionId  String?
  listingId String?
  // multi-target 수동 매칭: fulfillments가 있으면 listingId·optionId 대신 사용
  // (우선순위: fulfillments[] > listingId > optionId)

  space        Space                           @relation(fields: [spaceId],   references: [id], onDelete: Cascade)
  channel      Channel                         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  option       InvProductOption?               @relation(fields: [optionId],  references: [id], onDelete: Cascade)
  listing      ProductListing?                 @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fulfillments ChannelProductAliasFulfillment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, aliasName])
  @@index([spaceId])
  @@index([optionId])
  @@index([listingId])
}

// 수동 매칭 alias의 다중 fulfillment 자식 테이블.
// 한 raw name이 여러 (옵션, 수량)으로 팬아웃되는 경우(예: "블랙 2 + 화이트 1") 사용.
// quantity 의미: "1 주문당 perSet 수량" — import 시점에 orderItem.quantity 곱해져 실제 출고 수량 산출.
model ChannelProductAliasFulfillment {
  id       String @id @default(cuid())
  aliasId  String
  optionId String
  quantity Int

  alias  ChannelProductAlias @relation(fields: [aliasId], references: [id], onDelete: Cascade)
  option InvProductOption    @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@index([aliasId])
  @@index([optionId])
}

// 컬럼 매핑 프리셋 (업로드 시 header name → field 매핑을 저장)
model DelColumnMappingPreset {
  id        String  @id @default(cuid())
  spaceId   String
  name      String
  mapping   Json    // Array<{ headerName: string; field: string }>
  channelId String? // 프리셋 적용 시 배송 등록의 판매채널로 자동 입력될 채널

  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channel Channel? @relation("PresetChannel", fields: [channelId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([channelId])
}

// 데이터 연동 이력
model DelIntegrationHistory {
  id          String   @id @default(cuid())
  spaceId     String
  type        String   // "SALES" | "INVENTORY"
  dateFrom    DateTime
  dateTo      DateTime
  totalOrders Int
  movementIds String[]

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([spaceId])
}

// ─── 셀러 허브 공용 모델 ──────────────────────────────────────────────────────

// 브랜드 (상품에 연결, Space 단위)
model Brand {
  id      String  @id @default(cuid())
  spaceId String
  name    String
  logoUrl String?
  memo    String?

  space    Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  products InvProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 채널 그룹 (공용)
model ChannelGroup {
  id      String @id @default(cuid())
  spaceId String
  name    String

  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
}

// 공용 판매 채널
model Channel {
  id                  String      @id @default(cuid())
  spaceId             String
  groupId             String?
  name                String
  kind                ChannelKind @default(ONLINE_MARKETPLACE)
  isActive            Boolean     @default(true)
  adminUrl            String?
  freeShipping        Boolean     @default(false)
  usesMarketingBudget Boolean     @default(false)
  shippingFee         Decimal?    @db.Decimal(18, 2)
  vatIncludedInFee    Boolean     @default(true)
  requireOrderNumber  Boolean     @default(true)
  requirePayment      Boolean     @default(true)
  requireProducts     Boolean     @default(true)

  space        Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  group        ChannelGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  feeRates     ChannelFeeRate[]
  invMovements InvMovement[]
  delOrders    DelOrder[]
  columnMappingPresets DelColumnMappingPreset[] @relation("PresetChannel")
  productAliases       ChannelProductAlias[]
  productListings      ProductListing[]
  productGroupMeta     ProductChannelGroupMeta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([groupId])
}

// 채널별 카테고리 수수료율
model ChannelFeeRate {
  id           String  @id @default(cuid())
  channelId    String
  categoryName String
  ratePercent  Decimal @db.Decimal(6, 3)
  vatIncluded  Boolean @default(true)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, categoryName])
  @@index([channelId])
}

// 생산 차수 (Production Run) — 발주 단위. 여러 상품/옵션을 묶을 수 있음.
enum ProductionCostMode {
  TOTAL
  BREAKDOWN
}

model ProductionRun {
  id        String             @id @default(cuid())
  spaceId   String
  runNo     String                                                       // Space 단위 unique 차수 번호 (전체 범위)
  orderedAt DateTime                                                     // 발주일
  totalCost Decimal?           @db.Decimal(18, 2)                        // 총 생산원가 (TOTAL 모드: 직접 입력값 / BREAKDOWN 모드: costs 합계 캐시)
  costMode  ProductionCostMode @default(TOTAL)
  memo      String?

  space Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  items ProductionRunItem[]
  costs ProductionRunCost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, runNo])
  @@index([spaceId, orderedAt])
}

model ProductionRunItem {
  id       String @id @default(cuid())
  runId    String
  optionId String
  quantity Int

  run    ProductionRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  option InvProductOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([runId, optionId])
  @@index([optionId])
}

model ProductionRunCost {
  id          String   @id @default(cuid())
  runId       String
  itemName    String                                                  // 비용 항목 (필수)
  description String?                                                 // 상세 내용
  spec        Decimal? @db.Decimal(18, 4)                              // 규격 (선택)
  quantity    Decimal  @default(1) @db.Decimal(18, 4)                  // 수량 (필수, 기본 1)
  unitPrice   Decimal  @db.Decimal(18, 2)                              // 단가 (필수)
  amount      Decimal  @db.Decimal(18, 2)                              // (spec ?? 1) × quantity × unitPrice
  note        String?
  sortOrder   Int      @default(0)

  run ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// Space 단위 가격 시뮬레이션 기본값 (Phase 2 대비)
model ProductPricingSettings {
  id                      String  @id @default(cuid())
  spaceId                 String  @unique
  defaultOperatingCostPct Decimal @db.Decimal(6, 3) @default(0)
  defaultAdCostPct        Decimal @db.Decimal(6, 3) @default(0)
  defaultPackagingCost    Decimal @db.Decimal(18, 2) @default(0)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Space별 옵션 값-코드 자동 학습 사전
// 사용자가 상품 저장 시 속성 값의 코드를 수정하면 여기에 자동 upsert되고,
// 다음 상품 생성 시 에디터가 자동 제안한다 (Space 격리 + 시스템 사전보다 우선).
model SpaceOptionCodeAlias {
  id            String @id @default(cuid())
  spaceId       String
  attributeName String // "사이즈", "색상", "재질" ...
  value         String // "누드", "블랙" ...
  code          String // "NDE", "BLK" ... 사용자 커스텀 축약

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, attributeName, value])
  @@index([spaceId])
}

// ─── 판매채널 상품 (ProductListing) ─────────────────────────────────────────────
// 채널별로 상품을 묶음 단위(N개 옵션 × 수량)로 구성해 전용 상품명·키워드·판매가로 노출.
// 배송 업로드 매칭의 기본 단위 — 한 listing은 여러 fulfillment(실제 출고 옵션·수량)로 펼쳐진다.

model ProductListing {
  id           String               @id @default(cuid())
  spaceId      String
  channelId    String
  internalCode String?              // 사용자 관리용 식별자 (선택)
  searchName   String               // 상품명(검색용) — 채널 리스팅 상단 노출
  displayName  String               // 상품명(노출용) — 상세 페이지 타이틀
  keywords     Json                 @default("[]") // string[] — 사용자 확정 키워드
  retailPrice  Decimal?             @db.Decimal(18, 2) // 판매가격 (소비자가는 구성품에서 자동 계산)
  // 채널별 수동 재고 할당 상한 (세트 단위).
  // null이면 자동계산(min(floor(stock/qty))) 그대로 사용.
  // 값이 있으면 min(channelAllocation, 자동계산)으로 가용재고 제한.
  channelAllocation Int?
  status       ProductListingStatus @default(ACTIVE)
  memo         String?

  space    Space                 @relation(fields: [spaceId],   references: [id], onDelete: Cascade)
  channel  Channel               @relation(fields: [channelId], references: [id], onDelete: Cascade)
  items    ProductListingItem[]
  aliases  ChannelProductAlias[]
  delItems DelOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, searchName])
  @@index([spaceId, channelId])
  @@index([status])
}

// 판매채널 상품의 구성 옵션 (InvProductOption × 수량)
model ProductListingItem {
  id        String @id @default(cuid())
  listingId String
  optionId  String
  quantity  Int    // 묶음 내 수량 (세트면 2, 3 등)
  sortOrder Int    @default(0)

  listing ProductListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  option  InvProductOption @relation(fields: [optionId],  references: [id], onDelete: Restrict)

  @@unique([listingId, optionId])
  @@index([optionId])
}

// 배송 주문 아이템의 실제 출고 단위 — listing 매칭이면 1:N, 단일 옵션이면 비어있음
model DelOrderItemFulfillment {
  id          String @id @default(cuid())
  orderItemId String
  optionId    String
  quantity    Int    // listingItem.quantity × orderItem.quantity

  orderItem DelOrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    InvProductOption @relation(fields: [optionId],    references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([optionId])
}

// 상품 × 채널 그룹 단위 메타 — 같은 상품의 옵션 listing들을 한 상세 화면에서 묶어 관리할 때 공유되는 값
// 현재는 키워드만, 추후 대표 이미지/설명 등 확장 예정
model ProductChannelGroupMeta {
  id        String @id @default(cuid())
  spaceId   String
  productId String
  channelId String
  keywords  Json   @default("[]") // string[]

  space   Space      @relation(fields: [spaceId],   references: [id], onDelete: Cascade)
  product InvProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, channelId])
  @@index([spaceId, channelId])
}
