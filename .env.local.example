# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=

# 워커 인증 (맥미니 상주 워커 <-> 웹앱)
WORKER_API_KEY=

# AES-256-CBC 키 (64-char hex). ChannelCredential payload 암복호화에 사용.
# 신규 환경: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# ⚠️ 변경 시 기존 ChannelCredential row 복호화 불가 — 한 번 생성 후 고정.
ENCRYPTION_KEY=

# 기존 AI (쿠팡 분석 리포트용)
OPENROUTER_API_KEY=

# ─── Sales Content Deck (Unit 3+) ───────────────────────────────────────────

# Claude Code ACP — 기존 Bridge 서비스(port 18800) 확장 경로.
# Bridge 쪽에 `/sales-content/generate` 라우트가 준비되면 활성화된다.
# 빈 값이면 자동 fallback(Ollama) 또는 503.
CLAUDE_CODE_ACP_ENDPOINT=http://127.0.0.1:18800

# 로컬 Ollama (ACP fallback)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Gemini Imagen (이미지 AI). AI Studio API Key.
GOOGLE_AI_API_KEY=
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# 이미지 월간 크레딧 기본값 (WorkspaceAiCredit 초기 imageQuota)
SALES_CONTENT_IMAGE_MONTHLY_QUOTA=50

# (선택) sc job 실패(non-retryable) 알림 webhook. Slack incoming webhook 호환 — JSON {text}.
# 미설정 시 알림 없음 (db-stats / SQL 로 fallback 모니터링).
SC_FAILURE_WEBHOOK_URL=
