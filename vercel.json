{
  "framework": "nextjs",
  "buildCommand": "rm -rf .next && npx prisma migrate deploy && npx prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["icn1"],
  "functions": {
    "app/api/reports/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/sh/inventory/import/route.ts": {
      "maxDuration": 60
    },
    "app/api/sh/shipping/import/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/inventory-stale-check",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/reorder-settle",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/coupang-inventory-sync",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/coupang-sales-sync",
      "schedule": "0 5 * * *"
    }
  ]
}
