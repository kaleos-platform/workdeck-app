# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/agent/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# claude hooks 로그
.claude/hooks/*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
/src/generated/

# IDE 설정
.cursor/

# Playwright MCP 런타임 데이터
.playwright-mcp/

# shrimp task manager 런타임 데이터
/shrimp_data/

# Office 임시 잠금 파일 (Excel/Word 열려있을 때 생성)
~$*

# MCP 설정 (access token 포함 가능 — 개인별 로컬 관리)
.mcp.json

# Worker 런타임 데이터
/worker/node_modules
/worker/.browser-data
/worker/.downloads
/worker/.screenshots
/worker/.env
test-results/
